<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
  <%- include('partials/_head') %>
<body class="bg-gray-100 dark:bg-gray-950 min-h-screen flex items-center justify-center">
  <%- include('partials/_anti-flash') %>
  <main id="main-content" class="text-center px-4" role="main">
    <h1 class="text-6xl font-bold text-orange-700 mb-4"><%= typeof statusCode !== 'undefined' ? statusCode : '500' %></h1>
    <p class="text-xl text-gray-600 dark:text-gray-300 mb-6"><%= typeof message !== 'undefined' ? message : 'Error' %></p>
    <a href="/" class="text-orange-700 hover:underline focus:outline-none focus:ring-2 focus:ring-orange-700 rounded"><%= t('error.backHome') %></a>
  </main>
</body>
</html>