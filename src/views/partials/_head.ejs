<head>
  <% if (typeof GA_TRACKING_ID !== 'undefined' && GA_TRACKING_ID) { %>
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= GA_TRACKING_ID %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '<%= GA_TRACKING_ID %>');
    </script>
  <% } %>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof seo !== 'undefined' && seo.title ? seo.title : (typeof title !== 'undefined' ? title : 'Kontraktor — Find Trusted Contractors') %></title>
  <meta name="description" content="<%= typeof seo !== 'undefined' && seo.description ? seo.description : (typeof description !== 'undefined' ? description : 'Find and hire trusted contractors for your construction projects. Post a project, get bids, choose the best fit.') %>">
  <% if (typeof seo !== 'undefined' && seo.keywords) { %>
  <meta name="keywords" content="<%= seo.keywords %>">
  <% } %>
  <meta name="theme-color" content="#ea580c">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <!-- Canonical -->
  <% if (typeof seo !== 'undefined' && seo.canonical) { %>
  <link rel="canonical" href="<%= seo.canonical %>" />
  <% } else { %>
  <link rel="canonical" href="https://kontraktor.app<%= (typeof pagePath !== 'undefined' ? pagePath : '/') %>" />
  <% } %>
  <!-- Hreflang -->
  <% if (typeof seo !== 'undefined' && typeof renderAlternateLinks !== 'undefined') { %>
  <%- renderAlternateLinks(seo) %>
  <% } %>
  <!-- Open Graph -->
  <meta property="og:type" content="<%= typeof seo !== 'undefined' && seo.ogType ? seo.ogType : 'website' %>">
  <meta property="og:site_name" content="Kontraktor">
  <meta property="og:title" content="<%= typeof seo !== 'undefined' && seo.title ? seo.title : (typeof title !== 'undefined' ? title : 'Kontraktor — Find Trusted Contractors') %>">
  <meta property="og:description" content="<%= typeof seo !== 'undefined' && seo.description ? seo.description : (typeof description !== 'undefined' ? description : 'Find and hire trusted contractors for your construction projects.') %>">
  <meta property="og:url" content="<%= typeof seo !== 'undefined' && seo.canonical ? seo.canonical : (typeof ogUrl !== 'undefined' ? ogUrl : 'https://kontraktor.app') %>">
  <meta property="og:image" content="<%= typeof seo !== 'undefined' && seo.ogImage ? seo.ogImage : (typeof ogImage !== 'undefined' ? ogImage : 'https://kontraktor.app/og-image.png') %>">
  <% if (typeof seo !== 'undefined' && seo.publishedTime) { %>
  <meta property="article:published_time" content="<%= seo.publishedTime %>">
  <% } %>
  <!-- JSON-LD Structured Data -->
  <% if (typeof seo !== 'undefined' && typeof renderJsonLd !== 'undefined') { %>
  <%- renderJsonLd(seo) %>
  <% } %>
  <% if (typeof seo !== 'undefined' && seo.noIndex) { %>
  <meta name="robots" content="noindex, nofollow">
  <% } %>
  <!-- HTMX -->
  <script src="/js/htmx.min.js" defer></script>
  <!-- Main JS -->
  <script src="/js/main.js?v=<%= typeof cssVersion !== 'undefined' ? cssVersion : '1' %>" defer></script>
  <!-- Tailwind -->
  <link rel="stylesheet" href="/css/tailwind.css?v=<%= typeof cssVersion !== 'undefined' ? cssVersion : '1' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
