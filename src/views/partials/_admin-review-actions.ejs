<!-- Admin Review Actions - reusable approve/reject/delete -->
<%#
  Params:
    review — review object with .id, .is_approved, .is_moderated
%>
<% if (!review.is_approved || !review.is_moderated) { %>
<!-- Approve button -->
<form action="/api/admin/reviews/<%= review.id %>/moderate" method="POST" class="inline">
<%- include('../partials/csrf-field') %>
  <input type="hidden" name="action" value="approve">
  <!-- Compact (widescreen) -->
  <button type="submit" title="<%= t('admin.approve') %>" class="hidden min-[1600px]:inline-flex text-xs px-2.5 py-1 rounded border bg-gray-50 hover:bg-green-50 dark:bg-gray-800 dark:hover:bg-green-950/30 text-gray-500 hover:text-green-600 dark:text-gray-400 dark:hover:text-green-400 border-gray-200 dark:border-gray-700 hover:border-green-200 dark:hover:border-green-900/50 transition cursor-pointer whitespace-nowrap">✓</button>
  <!-- Full (mobile/tablet) -->
  <button type="submit" class="min-[1600px]:hidden text-xs px-3 py-1.5 rounded-lg border bg-white dark:bg-gray-800 text-green-600 dark:text-green-400 border-green-300 dark:border-green-800 hover:bg-green-50 dark:hover:bg-green-950/20 transition cursor-pointer whitespace-nowrap"><%= t('admin.approve') %></button>
</form>
<!-- Reject button -->
<form action="/api/admin/reviews/<%= review.id %>/moderate" method="POST" class="inline">
<%- include('../partials/csrf-field') %>
  <input type="hidden" name="action" value="reject">
  <!-- Compact -->
  <button type="submit" title="<%= t('admin.reject') %>" class="hidden min-[1600px]:inline-flex text-xs px-2.5 py-1 rounded border bg-gray-50 hover:bg-red-50 dark:bg-gray-800 dark:hover:bg-red-950/30 text-gray-500 hover:text-red-600 dark:text-gray-400 dark:hover:text-red-400 border-gray-200 dark:border-gray-700 hover:border-red-200 dark:hover:border-red-900/50 transition cursor-pointer whitespace-nowrap">✗</button>
  <!-- Full -->
  <button type="submit" class="min-[1600px]:hidden text-xs px-3 py-1.5 rounded-lg border bg-white dark:bg-gray-800 text-red-500 dark:text-red-400 border-red-300 dark:border-red-800 hover:bg-red-50 dark:hover:bg-red-950/20 transition cursor-pointer whitespace-nowrap"><%= t('admin.reject') %></button>
</form>
<% } %>
<!-- Delete button (always visible) -->
<form action="/api/admin/reviews/<%= review.id %>/delete" method="POST" class="inline" data-confirm="<%= typeof t !== 'undefined' ? t('admin.deleteReviewConfirm') : 'Delete this review?' %>">
<%- include('../partials/csrf-field') %>
  <!-- Compact -->
  <button type="submit" title="<%= t('admin.delete') %>" class="hidden min-[1600px]:inline-flex text-xs px-2.5 py-1 rounded border bg-gray-50 hover:bg-red-50 dark:bg-gray-800 dark:hover:bg-red-950/30 text-gray-500 hover:text-red-600 dark:text-gray-400 dark:hover:text-red-400 border-gray-200 dark:border-gray-700 hover:border-red-200 dark:hover:border-red-900/50 transition cursor-pointer whitespace-nowrap">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
    </svg>
  </button>
  <!-- Full -->
  <button type="submit" title="<%= t('admin.delete') %>" class="min-[1600px]:hidden text-xs px-3 py-1.5 rounded-lg border bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 border-gray-300 dark:border-gray-600 hover:bg-red-50 dark:hover:bg-red-950/20 transition cursor-pointer whitespace-nowrap">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
    </svg>
  </button>
</form>
