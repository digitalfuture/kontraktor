<section id="cta" class="py-12 sm:py-16 lg:py-24 bg-gradient-to-br from-orange-700 to-orange-600 dark:from-orange-800 dark:to-orange-700" aria-labelledby="cta-title">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 id="cta-title" class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-4"><%= t('cta.title') %></h2>
    <p class="text-lg text-white dark:text-white mb-8 max-w-xl mx-auto"><%= t('cta.subtitle') %></p>
    <a href="/post" class="bg-gradient-to-r from-orange-600 to-amber-500 text-white px-8 py-3 rounded-lg hover:from-orange-700 hover:to-amber-600 transition font-semibold text-lg shadow-button hover:shadow-button-hover focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-orange-700">
      <%= t('cta.button') %>
    </a>
  </div>
</section>
