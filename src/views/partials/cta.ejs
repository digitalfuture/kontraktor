<section id="cta" class="py-12 sm:py-16 lg:py-24 bg-orange-700 dark:bg-orange-800" aria-labelledby="cta-title">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 id="cta-title" class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-4"><%= t('cta.title') %></h2>
    <p class="text-lg text-white dark:text-white mb-8 max-w-xl mx-auto"><%= t('cta.subtitle') %></p>
    <a href="/post" class="bg-white text-orange-700 px-8 py-3 rounded-lg hover:bg-orange-50 transition font-semibold text-lg shadow-lg focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-orange-700">
      <%= t('cta.button') %>
    </a>
  </div>
</section>
