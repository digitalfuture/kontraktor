<!-- Shared sidebar branding header -->
<div class="px-4 py-2 min-h-[3.25rem] border-b border-gray-800 flex items-center justify-between">
  <div class="flex items-center gap-3">
    <!-- Close button (visible only below sidebar breakpoint) -->
    <button onclick="const a=document.querySelector('aside');a.classList.add('-translate-x-full');a.classList.remove('translate-x-0')" class="<%= typeof sidebarBreakpoint !== 'undefined' ? sidebarBreakpoint : 'min-[1200px]' %>:hidden p-2 rounded-lg hover:bg-gray-800 active:bg-gray-700 text-gray-400 cursor-pointer transition-colors focus:outline-none" aria-label="Close sidebar">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <div class="flex items-baseline gap-2">
      <a href="/" class="text-lg font-bold text-orange-500 leading-none">Kontraktor</a>
      <p class="text-xs text-gray-400 leading-none"><%= typeof subtitle !== 'undefined' ? subtitle : '' %></p>
    </div>
  </div>
  <!-- Tailwind safelist (used dynamically): min-[1200px]:hidden min-[1600px]:hidden -->
  <span class="hidden min-[1200px]:hidden min-[1600px]:hidden" aria-hidden="true"></span>
</div>
