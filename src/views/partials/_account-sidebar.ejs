<aside class="fixed inset-y-0 left-0 z-40 w-64 bg-gray-900 dark:bg-gray-950 text-white flex flex-col border-r border-gray-800 dark:border-gray-800 transform -translate-x-full min-[1200px]:translate-x-0 min-[1200px]:sticky min-[1200px]:top-0 min-[1200px]:h-svh transition-transform duration-300 ease-in-out">
  <%- include('_sidebar-header', { sidebarBreakpoint: 'min-[1200px]', subtitle: typeof t !== 'undefined' ? t('account.title') : 'Account' }) %>
  
  <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
    <!-- Overview -->
    <a href="/account" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activeSection !== 'undefined' && activeSection === 'overview' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      <%= typeof t !== 'undefined' ? t('account.overview') : 'Overview' %>
    </a>

    <!-- Client section header -->
    <div class="pt-4 pb-1 px-4">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= typeof t !== 'undefined' ? t('account.clientSection') : 'Client' %></p>
    </div>

    <a href="/account?section=projects" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activeSection !== 'undefined' && activeSection === 'projects' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      <%= typeof t !== 'undefined' ? t('account.clientOrders') : 'My Projects' %>
    </a>

    <a href="/post" class="flex items-center gap-3 px-4 py-3 rounded-lg transition text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <%= typeof t !== 'undefined' ? t('nav.postOrder') : 'Post a Project' %>
    </a>

    <!-- Contractor section (only for registered contractors) -->
    <% if (typeof isContractor !== 'undefined' && isContractor) { %>
    <div class="pt-4 pb-1 px-4">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500"><%= typeof t !== 'undefined' ? t('account.contractorSection') : 'Contractor' %></p>
    </div>

    <a href="/account?section=bids" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activeSection !== 'undefined' && activeSection === 'bids' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <%= typeof t !== 'undefined' ? t('account.myBids') : 'My Bids' %>
    </a>

    <a href="/projects" class="flex items-center gap-3 px-4 py-3 rounded-lg transition text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <%= typeof t !== 'undefined' ? t('nav.browseProjects') : 'Browse Projects' %>
    </a>

    <a href="/contractors/dashboard" class="flex items-center gap-3 px-4 py-3 rounded-lg transition text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      <%= typeof t !== 'undefined' ? t('account.contractorDashboard') : 'Contractor Dashboard' %>
    </a>
    <% } %>
  </nav>
  
  <div class="p-4 border-t border-gray-800">
    <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800 transition text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m0 0h12"/></svg>
      <%= typeof t !== 'undefined' ? t('nav.home') : 'Back to site' %>
    </a>
    <a href="/auth/logout" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-red-400 transition text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      <%= typeof t !== 'undefined' ? t('nav.logout') : 'Logout' %>
    </a>
  </div>
</aside>
