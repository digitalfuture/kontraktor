<section id="reviews" class="py-12 sm:py-16 lg:py-24 bg-gradient-to-b from-gray-200 to-gray-100 dark:from-gray-950 dark:to-gray-900" aria-labelledby="reviews-title">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="reviews-title" class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white"><%= t('reviews.title') %></h2>
      <p class="mt-3 text-gray-600 dark:text-gray-300"><%= t('reviews.subtitle') %></p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% reviews.slice(0, 3).forEach(function(r) { %>
        <figure class="bg-surface dark:bg-surface-dark rounded-card p-6 border border-gray-200 dark:border-gray-800 shadow-card flex flex-col">
          <blockquote class="flex-1">
            <div class="flex items-center gap-1 mb-3" role="img" aria-label="<%= r.rating %> out of 5 stars">
              <% for (var s = 0; s < Math.min(5, Math.max(0, r.rating || 0)); s++) { %>
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
              <% for (var s = 0; s < 5 - Math.min(5, Math.max(0, r.rating || 0)); s++) { %>
                <svg class="w-5 h-5 text-gray-200 dark:text-gray-700" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
            </div>
            <p class="text-gray-700 dark:text-gray-300">"<%= r.comment %>"</p>
          </blockquote>
          <figcaption class="flex items-center gap-3 mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
            <div class="w-10 h-10 bg-gray-300 dark:bg-gray-700 rounded-full flex items-center justify-center text-sm font-bold text-gray-600 dark:text-gray-300" aria-hidden="true"><%= r.author_email ? r.author_email.charAt(0).toUpperCase() : '?' %></div>
            <div>
              <cite class="not-italic font-medium text-gray-900 dark:text-white"><%= r.author_email ? r.author_email.split('@')[0] : 'Client' %></cite>
            </div>
          </figcaption>
        </figure>
      <% }); %>
    </div>
  </div>
</section>