<!-- <%= t("header.skipToMain") %> (accessibility) -->
<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-orange-700 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-700">
  <%= t("header.skipToMain") %>
</a>

<header class="bg-white dark:bg-gray-900 sticky top-0 z-50" role="banner">
  <!-- Thin gradient accent bar -->
  <div class="h-0.5 bg-gradient-to-r from-orange-500 via-orange-400 to-amber-500"></div>
  <div class="border-b border-gray-200 dark:border-gray-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="text-2xl font-bold text-orange-700 hover:text-orange-700 transition" aria-label="<%= t("header.logoLabel") %>">
          Kontraktor
        </a>
      </div>
      
      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center space-x-6" aria-label="Main navigation">
        <a href="/services" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition"><%= t('nav.services') %></a>
        <% if (typeof user !== 'undefined' && user) { %><a href="/projects" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition"><%= t('projects.title') %></a><% } %>
        <a href="/contractors" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition"><%= t('nav.contractors') %></a>
      </nav>
      
      <!-- Desktop Controls (Lang + Theme) -->
      <div class="hidden md:flex items-center space-x-3">
        <!-- Language Switcher -->
        <div class="flex items-center space-x-1" role="group" aria-label="Language switcher">
          <% locales.forEach(function(loc) { %>
            <a href="?lang=<%= loc %>" 
               class="px-2 py-1 rounded text-sm font-medium transition
                 <%= locale === loc ? 'bg-orange-100 dark:bg-orange-900/40 text-orange-700' : 'text-gray-500 dark:text-gray-300 hover:text-gray-700 dark:hover:text-gray-200' %>"
            >
              <%= loc.toUpperCase() %>
            </a>
          <% }); %>
        </div>
        
        <!-- Theme Toggle -->
        <button id="theme-toggle" class="p-2 rounded-lg text-gray-500 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition" aria-label="Toggle dark mode">
          <!-- Sun icon (shown in dark mode) -->
          <svg id="theme-toggle-sun" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"/>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg id="theme-toggle-moon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/>
          </svg>
        </button>
      </div>
      
      <!-- Auth / Account -->
      <div class="hidden md:flex items-center space-x-4" role="navigation" aria-label="Account">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/account" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition font-medium"><%= t('nav.account') %></a>
          <% if (user.role === 'contractor') { %>
            <a href="/contractors/dashboard" class="text-orange-700 dark:text-orange-400 hover:text-orange-700 transition font-medium" aria-label="<%= t('contractorDashboard.myBids') %>">📋 <%= t('contractorDashboard.myBids') %></a>
          <% } %>
          <% if (user.role === 'admin') { %>
            <a href="/admin" class="text-gray-500 dark:text-gray-300 hover:text-orange-600 transition text-sm">⚙️ <%= t('nav.admin') %></a>
          <% } %>
          <a href="/auth/logout" class="text-gray-500 dark:text-gray-300 hover:text-red-600 transition text-sm"><%= t('nav.logout') %></a>
        <% } else { %>
          <a href="/auth/login" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition font-medium"><%= t('nav.login') %></a>
        <% } %>
        <a href="/post" class="bg-gradient-to-r from-orange-600 to-amber-500 text-white px-5 py-2 rounded-lg hover:from-orange-700 hover:to-amber-600 transition font-medium shadow-button hover:shadow-button-hover focus:outline-none focus:ring-2 focus:ring-orange-700 focus:ring-offset-2">
          <%= t('nav.postOrder') %>
        </a>
      </div>
      
      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-md text-gray-700 dark:text-gray-300 hover:text-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-700" aria-label="<%= t("header.openMenu") %>" aria-expanded="false">
        <!-- Hamburger icon (visible when closed) -->
        <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <!-- Close (cross) icon (visible when open) -->
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4" role="navigation" aria-label="Mobile navigation">
      <nav class="flex flex-col space-y-3">
        <a href="/services" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition py-2"><%= t('nav.services') %></a>
        <% if (typeof user !== 'undefined' && user) { %><a href="/projects" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition py-2"><%= t('projects.title') %></a><% } %>
        <a href="/contractors" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition py-2"><%= t('nav.contractors') %></a>
        
        <!-- Mobile Controls -->
        <div class="flex items-center space-x-4 py-2">
          <!-- Mobile Language Switcher -->
          <div class="flex space-x-2" role="group" aria-label="Language switcher">
            <% locales.forEach(function(loc) { %>
              <a href="?lang=<%= loc %>" 
                 class="px-2 py-1 rounded text-sm font-medium transition
                   <%= locale === loc ? 'bg-orange-100 dark:bg-orange-900/40 text-orange-700' : 'text-gray-500 dark:text-gray-300' %>"
              >
                <%= loc.toUpperCase() %>
              </a>
            <% }); %>
          </div>
          
          <!-- Mobile Theme Toggle -->
          <button id="mobile-theme-toggle" class="p-2 rounded-lg text-gray-500 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition" aria-label="Toggle dark mode">
            <svg class="mobile-theme-sun w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"/>
            </svg>
            <svg class="mobile-theme-moon w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/>
            </svg>
          </button>
        </div>
        
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/account" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition py-2 font-medium"><%= t('nav.account') %></a>
          <% if (user.role === 'contractor') { %>
            <a href="/contractors/dashboard" class="text-orange-700 dark:text-orange-400 hover:text-orange-700 transition py-2 font-medium">📋 <%= t('contractorDashboard.myBids') %></a>
          <% } %>
          <% if (user.role === 'admin') { %>
            <a href="/admin" class="text-gray-500 dark:text-gray-300 hover:text-orange-600 transition py-2 text-sm">⚙️ <%= t('nav.admin') %></a>
          <% } %>
          <a href="/auth/logout" class="text-gray-500 dark:text-gray-300 hover:text-red-600 transition py-2 text-sm"><%= t('nav.logout') %></a>
        <% } else { %>
          <a href="/auth/login" class="text-gray-700 dark:text-gray-300 hover:text-orange-600 transition py-2 font-medium"><%= t('nav.login') %></a>
        <% } %>
        <a href="/post" class="bg-gradient-to-r from-orange-600 to-amber-500 text-white px-5 py-2 rounded-lg hover:from-orange-700 hover:to-amber-600 transition font-medium text-center shadow-button hover:shadow-button-hover focus:outline-none focus:ring-2 focus:ring-orange-700 focus:ring-offset-2">
          <%= t('nav.postOrder') %>
        </a>
      </nav>
    </div>
  </div>
  </div> <!-- /border-b -->
</header>