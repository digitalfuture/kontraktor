<section id="services" class="py-12 sm:py-16 lg:py-24 bg-gray-200 dark:bg-gray-950" aria-labelledby="services-title">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="services-title" class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white"><%= t('services.title') %></h2>
      <p class="mt-3 text-gray-600 dark:text-gray-300"><%= t('services.subtitle') %></p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% const serviceSlugs = ['apartment-renovation', 'electrical-work', 'plumbing', 'finishing', 'construction', 'roofing', 'facade', 'landscaping', 'demolition']; %>
      <% serviceSlugs.forEach(function(slug) { %>
        <% const svc = services.find(s => s.slug === slug); %>
        <% if (svc) { %>
          <a href="/services/<%= slug %>" class="bg-surface dark:bg-surface-dark dark:border-gray-700 border border-gray-200 rounded-card p-6 hover:shadow-card-hover shadow-card transition block flex flex-col focus:outline-none focus:ring-2 focus:ring-orange-700 focus:ring-offset-2">
            <div class="w-12 h-12 bg-orange-50 dark:bg-orange-900/40 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-orange-500 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><%- iconMap[slug] || defaultIcon %></svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white"><%= t('services.cats.' + slug + '.name') %></h3>
            <p class="mt-2 text-gray-600 dark:text-gray-300 text-sm flex-1"><%= t('services.cats.' + slug + '.desc') %></p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-orange-700 dark:text-orange-400 font-medium">
                <% if (svc.hasContractors) { %>
                  <%= svc.marketPrice || t('services.cats.' + slug + '.price') %>
                <% } else { %>
                  <%= svc.marketPrice || t('services.cats.' + slug + '.price') %> <span class="text-xs text-gray-500 dark:text-gray-400 ml-1"><%= t('services.marketPrice') %></span>
                <% } %>
              </span>
              <span class="text-gray-600 dark:text-gray-300 text-sm">
                <%= svc.totalContractors %> <%= t('services.contractors') %>
              </span>
            </div>
          </a>
        <% } else { %>
          <div class="bg-gray-100 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-card p-6 opacity-60 flex flex-col shadow-card">
            <div class="w-12 h-12 bg-gray-200 dark:bg-gray-600 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><%- iconMap[slug] || defaultIcon %></svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white"><%= t('services.cats.' + slug + '.name') %></h3>
            <p class="mt-2 text-gray-600 dark:text-gray-300 text-sm flex-1"><%= t('services.cats.' + slug + '.desc') %></p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-gray-500 dark:text-gray-400 font-medium"><%= t('services.cats.' + slug + '.price') %> <span class="text-xs ml-1"><%= t('services.marketPrice') %></span></span>
              <span class="text-gray-500 dark:text-gray-400 text-sm">0 <%= t('services.contractors') %></span>
            </div>
          </div>
        <% } %>
      <% }); %>
    </div>
  </div>
</section>