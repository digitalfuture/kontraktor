<section id="how-it-works" class="py-12 sm:py-16 bg-gradient-to-t from-gray-200 via-gray-100 to-orange-100/50 dark:from-gray-950 dark:via-gray-900 dark:to-orange-950/30" aria-labelledby="how-title">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="how-title" class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white"><%= t('howItWorks.title') %></h2>
      <p class="mt-2 text-gray-600 dark:text-gray-300"><%= t('howItWorks.subtitle') %></p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% t('howItWorks.steps').forEach(function(step, i) { %>
        <div class="text-center">
          <div class="w-12 h-12 bg-orange-700 text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4">
            <%= i + 1 %>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2"><%= step.title %></h3>
          <p class="text-gray-600 dark:text-gray-300"><%= step.desc %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>
