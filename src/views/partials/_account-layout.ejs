<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
  <%- include('_head') %>
<body class="bg-gray-100 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
  <%- include('_anti-flash') %>
  <div class="flex flex-col min-h-screen">
    <div class="flex flex-1 min-h-0">
      <%- include('_account-sidebar', { activeSection: typeof activeSection !== 'undefined' ? activeSection : 'overview', t: typeof t !== 'undefined' ? t : null, locale: locale, isContractor: typeof isContractor !== 'undefined' ? isContractor : false }) %>
      <div class="flex flex-col flex-1 min-w-0">
        <!-- Account header bar (shared component) -->
        <%- include('_page-header', { 
          sidebarBreakpoint: 'min-[1200px]',
          mobileBranding: '',
          mobileBrandingLink: '',
          desktopSubtitle: '',
          pageTitle: '',
          isAdmin: false,
          controlsIdPrefix: 'account',
          locale: typeof locale !== 'undefined' ? locale : 'en',
          locales: typeof locales !== 'undefined' ? locales : ['id', 'en'],
          showAdminLink: true,
          showAccountLink: false,
          extraLangParams: typeof activeSection !== 'undefined' && activeSection !== 'overview' ? '&section=' + activeSection : '',
          t: typeof t !== 'undefined' ? t : null,
          user: typeof user !== 'undefined' ? user : null
        }) %>
        <main class="flex-1 overflow-y-auto">
          <div class="p-4 sm:p-6 lg:p-8">
