<section id="contact-form-section" class="text-gray-300">
  <% if (typeof success !== 'undefined' && success) { %>
    <p class="text-green-400 text-sm mb-2"><%= t('contact.formSuccess') %></p>
  <% } else if (typeof error !== 'undefined' && error) { %>
    <p class="text-red-400 text-sm mb-2"><%= error %></p>
  <% } %>
  <form id="contact-form" action="/contact" method="POST" hx-post="/contact" hx-target="#contact-form-section" hx-swap="innerHTML" class="space-y-2">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <!-- Honeypot anti-spam: hidden field that bots fill but humans don't see -->
    <input type="text" name="website" value="" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;height:0;" aria-hidden="true">
    <div>
      <label for="contact-name" class="sr-only"><%= t('contact.name') %></label>
      <input type="text" id="contact-name" name="name" value="<%= typeof name !== 'undefined' ? name : (typeof user !== 'undefined' && user ? user.name : '') %>"
        placeholder="<%= t('contact.name') %>"
        class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent"
        required>
    </div>
    <div>
      <label for="contact-email" class="sr-only"><%= t('contact.email') %></label>
      <input type="email" id="contact-email" name="email" value="<%= typeof email !== 'undefined' ? email : (typeof user !== 'undefined' && user ? user.email : '') %>"
        placeholder="<%= t('contact.email') %>"
        class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent"
        required>
    </div>
    <div>
      <label for="contact-message" class="sr-only"><%= t('contact.message') %></label>
      <textarea id="contact-message" name="message" rows="3"
        placeholder="<%= t('contact.message') %>"
        class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent resize-none"
        required><%= typeof message !== 'undefined' ? message : '' %></textarea>
    </div>
    <button type="submit"
      class="w-full bg-orange-600 hover:bg-orange-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition focus:outline-none focus:ring-2 focus:ring-orange-700 focus:ring-offset-2 focus:ring-offset-gray-900">
      <%= t('contact.send') %>
    </button>
  </form>
</section>
