<!-- Admin Order Status Form - reusable status change with auto-disable -->
<%#
  Params:
    order — order object with .id, .status
%>
<form action="/api/admin/projects/<%= order.id %>/status" method="POST" class="flex gap-1 items-center flex-nowrap whitespace-nowrap">
<%- include('../partials/csrf-field') %>
  <!-- Compact select (widescreen) -->
  <select name="status" data-original="<%= order.status %>" onchange="this.form.querySelector('button[type=submit]').disabled=!this.value||this.value===this.dataset.original" class="hidden min-[1600px]:inline-block text-xs px-1.5 py-1 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 cursor-pointer whitespace-nowrap">
    <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>><%= t('admin.pending') %></option>
    <option value="in_progress" <%= order.status === 'in_progress' ? 'selected' : '' %>><%= t('admin.inProgress') %></option>
    <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>><%= t('admin.done') %></option>
    <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>><%= t('admin.cancelLabel') %></option>
  </select>
  <!-- Compact button -->
  <button type="submit" disabled class="hidden min-[1600px]:inline-flex text-xs px-2.5 py-1 rounded bg-gray-100 dark:bg-gray-700 hover:bg-orange-600 dark:hover:bg-orange-600 text-gray-700 dark:text-gray-300 hover:text-white dark:hover:text-white border border-gray-300 dark:border-gray-600 hover:border-orange-500 disabled:opacity-40 disabled:cursor-default disabled:hover:bg-gray-100 dark:disabled:hover:bg-gray-700 disabled:hover:text-gray-700 dark:disabled:hover:text-gray-300 disabled:hover:border-gray-300 dark:disabled:hover:border-gray-600 transition cursor-pointer whitespace-nowrap">→</button>
</form>
<form action="/api/admin/projects/<%= order.id %>/status" method="POST" class="flex gap-2 items-center">
<%- include('../partials/csrf-field') %>
  <!-- Full select (mobile/tablet) -->
  <select name="status" data-original="<%= order.status %>" onchange="this.form.querySelector('button[type=submit]').disabled=!this.value||this.value===this.dataset.original" class="min-[1600px]:hidden px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-orange-500 outline-none">
    <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>><%= t('admin.pending') %></option>
    <option value="in_progress" <%= order.status === 'in_progress' ? 'selected' : '' %>><%= t('admin.inProgress') %></option>
    <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>><%= t('admin.done') %></option>
    <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>><%= t('admin.cancelLabel') %></option>
  </select>
  <!-- Full button -->
  <button type="submit" disabled class="min-[1600px]:hidden px-4 py-2 text-sm rounded-lg bg-orange-700 text-white hover:bg-orange-800 disabled:opacity-40 disabled:cursor-default disabled:bg-orange-700 disabled:hover:bg-orange-700 transition font-medium"><%= t('admin.save') %></button>
</form>

<script>
(function() {
  var handler = function() {
    document.querySelectorAll('select[data-original]').forEach(function(sel) {
      var form = sel.closest('form');
      if (!form) return;
      var btn = form.querySelector('button[type="submit"]');
      if (btn) btn.disabled = !sel.value || sel.value === sel.dataset.original;
    });
  };
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', handler);
  } else {
    handler();
  }
})();
</script>
