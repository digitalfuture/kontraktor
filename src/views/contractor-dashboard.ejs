<!DOCTYPE html>
<html lang="<%= locale %>">
<%- include('partials/_head') %>
<body class="bg-gray-200 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
  <%- include('partials/_anti-flash') %>
  <%- include('partials/header') %>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <!-- Success/Error messages -->
    <% if (success === 'avatar') { %>
    <div class="mb-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg text-green-700 dark:text-green-300">
      ✅ <%= t('contractorDashboard.avatarUpdated') %>
    </div>
    <% } else if (success === 'portfolio') { %>
    <div class="mb-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg text-green-700 dark:text-green-300">
      ✅ <%= t('contractorDashboard.photosUploaded') %>
    </div>
    <% } else if (success === 'photo_deleted') { %>
    <div class="mb-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg text-green-700 dark:text-green-300">
      ✅ <%= t('contractorDashboard.photoDeleted') %>
    </div>
    <% } else if (error) { %>
    <div class="mb-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-red-700 dark:text-red-300">
      ❌ <%= t('contractorDashboard.uploadFailed') %>
    </div>
    <% } %>

    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
      <div class="flex items-center gap-4">
        <!-- Avatar upload form -->
        <div class="relative group">
          <% if (contractor.avatar_url) { %>
          <img src="<%= contractor.avatar_url %>" alt="<%= t("contractorDashboard.avatar") %>" class="w-16 h-16 rounded-full object-cover border-2 border-orange-200 dark:border-orange-800" loading="lazy" width="64" height="64">
          <% } else { %>
          <div class="w-16 h-16 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-2xl font-bold text-orange-700 border-2 border-orange-200 dark:border-orange-800">
            <%= (contractor.name || '?')[0].toUpperCase() %>
          </div>
          <% } %>
          <label class="absolute inset-0 flex items-center justify-center bg-black/50 rounded-full opacity-0 group-hover:opacity-100 transition cursor-pointer" title="Change avatar">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp,image/gif" class="hidden" onchange="this.form.submit()">
          </label>
          <form action="/contractors/dashboard/avatar?_csrf=<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" method="POST" enctype="multipart/form-data" class="absolute inset-0"></form>
        </div>
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold"><%= t('contractorDashboard.title') %></h1>
          <p class="text-gray-600 dark:text-gray-300 mt-1"><%= t('contractorDashboard.welcomeBack') %>, <%= contractor.name %></p>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <div class="bg-orange-100 dark:bg-orange-900/30 px-4 py-2 rounded-lg">
          <span class="text-sm text-gray-600 dark:text-gray-300"><%= t('contractorDashboard.credits') %>:</span>
          <span class="text-xl font-bold text-orange-700 ml-1"><%= contractor.credits || 0 %></span>
        </div>
        <a href="/payments/buy" class="border border-orange-300 dark:border-orange-700 text-orange-700 dark:text-orange-400 hover:bg-orange-50 dark:hover:bg-orange-950/20 text-sm font-medium py-2 px-4 rounded-lg transition inline-flex items-center gap-1">
          💰 <%= locale === 'id' ? 'Beli Kredit' : 'Buy Credits' %>
        </a>
        <form action="/contractors/request-credits" method="POST" class="flex items-center gap-2">
          <%- include('partials/csrf-field') %>
          <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-4 rounded-lg transition">
            <%= t('contractorDashboard.requestCredits') %>
          </button>
        </form>
      </div>
    </div>

    <!-- Stats cards -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
<div class="bg-surface dark:bg-surface-dark rounded-card shadow-card border border-gray-200 dark:border-gray-700">
        <p class="text-sm text-gray-500 dark:text-gray-300"><%= t('contractorDashboard.totalBids') %></p>
        <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= stats.total %></p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-yellow-200 dark:border-yellow-800 p-4">
        <p class="text-sm text-yellow-600 dark:text-yellow-400"><%= t('contractorDashboard.pending') %></p>
        <p class="text-2xl font-bold text-yellow-600 dark:text-yellow-400 mt-1"><%= stats.pending %></p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-green-200 dark:border-green-800 p-4">
        <p class="text-sm text-green-600 dark:text-green-400"><%= t('contractorDashboard.accepted') %></p>
        <p class="text-2xl font-bold text-green-600 dark:text-green-400 mt-1"><%= stats.accepted %></p>
      </div>
<div class="bg-surface dark:bg-surface-dark rounded-card shadow-card border border-gray-200 dark:border-gray-700">
        <p class="text-sm text-gray-500 dark:text-gray-300"><%= t('contractorDashboard.declined') %></p>
        <p class="text-2xl font-bold text-gray-500 dark:text-gray-300 mt-1"><%= stats.rejected %></p>
      </div>
    </div>

    <!-- Bids list -->
<div class="bg-surface dark:bg-surface-dark rounded-card shadow-card border border-gray-200 dark:border-gray-700">
      <div class="p-6 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-bold"><%= t('contractorDashboard.myBids') %></h2>
      </div>

      <% if (bids.length === 0) { %>
      <div class="p-12 text-center">
        <p class="text-gray-500 dark:text-gray-300 text-lg mb-4"><%= t('contractorDashboard.noBidsYet') %></p>
        <a href="/projects" class="inline-block bg-orange-700 text-white px-6 py-2 rounded-lg hover:bg-orange-800 transition font-medium">
          <%= t('contractorDashboard.browseProjects') %>
        </a>
      </div>
      <% } else { %>
      <div class="divide-y divide-gray-200 dark:divide-gray-700">
        <% bids.forEach(function(bid) { %>
        <div class="p-4 sm:p-6 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div class="flex-1 min-w-0">
              <a href="/post/<%= bid.project_id %>" class="font-semibold text-gray-900 dark:text-white hover:text-orange-600 truncate block">
                <%= bid.project_title %>
              </a>
              <div class="flex items-center gap-3 mt-1 text-sm text-gray-500 dark:text-gray-300">
                <span>📁 <%= bid.category_display %></span>
                <% if (bid.price) { %>
                <span>💵 <%= t('projectDetail.priceLabel') %>: Rp <%= bid.price %></span>
                <% } %>
              </div>
              <p class="text-sm text-gray-400 dark:text-gray-500 mt-1"><%= new Date(bid.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
            </div>
            <div>
              <%- include('partials/_status-badge', { status: bid.status, type: 'project' }) %>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>

    <!-- Portfolio Photos -->
<div class="bg-surface dark:bg-surface-dark rounded-card shadow-card border border-gray-200 dark:border-gray-700">
      <div class="p-6 border-b border-gray-200 dark:border-gray-700 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <h2 class="text-lg font-bold">📸 <%= t('contractorDashboard.portfolio') %></h2>
        <!-- Upload form -->
        <form action="/contractors/dashboard/portfolio?_csrf=<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" method="POST" enctype="multipart/form-data" class="flex items-center gap-2">
          <label class="cursor-pointer bg-orange-700 text-white px-4 py-2 rounded-lg hover:bg-orange-800 transition text-sm font-medium flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <%= t('contractorDashboard.addPhotos') %>
            <input type="file" name="photos" accept="image/jpeg,image/png,image/webp,image/gif" multiple class="hidden" id="portfolio-upload">
          </label>
          <button type="submit" class="bg-gray-800 text-white px-4 py-2 rounded-lg hover:bg-gray-900 transition text-sm font-medium"><%= t('contractorDashboard.upload') %></button>
        </form>
      </div>

      <% if (photos && photos.length > 0) { %>
      <div class="p-6">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          <% photos.forEach(function(photo) { %>
          <div class="relative group">
            <img src="/uploads/<%= photo.filename %>" alt="<%= photo.caption || '' %>" class="w-full h-40 object-cover rounded-lg border border-gray-200 dark:border-gray-700" loading="lazy">
            <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition rounded-lg flex flex-col items-center justify-center gap-2">
              <p class="text-white text-xs text-center px-2 truncate w-full"><%= photo.caption || photo.original_name %></p>
              <form action="/contractors/dashboard/photo/<%= photo.id %>/delete?_csrf=<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" method="POST" onsubmit="return confirm('<%= t('contractorDashboard.deletePhotoConfirm') %>')">
                <button type="submit" class="text-red-400 hover:text-red-300 text-sm font-medium">🗑️ <%= t('contractorDashboard.deletePhoto') %></button>
              </form>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% } else { %>
      <div class="p-12 text-center">
        <p class="text-gray-500 dark:text-gray-300 text-lg mb-2"><%= t('contractorDashboard.noPortfolio') %></p>
        <p class="text-gray-400 dark:text-gray-500 text-sm"><%= t('contractorDashboard.noPortfolioSub') %></p>
      </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>