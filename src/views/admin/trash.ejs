                  </form>
                  <form action="/api/admin/reviews/<%= r.id %>/force-delete" hx-target="#review-<%= r.id %>" hx-swap="outerHTML swap:300ms" data-confirm="<%= t('admin.confirmDelete') || 'Are you sure?' %>">
                    <%- include('../partials/csrf-field') %>
                    <button type="submit" data-requires-edit class="w-auto text-sm font-medium px-3 py-2 rounded-lg border border-red-600 text-red-600 hover:bg-red-50 dark:hover:bg-red-950/20 transition cursor-pointer" title="<%= t('admin.delete') %>">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                    </button>
                  </form>
                </div>
              </div>
              <% }); %>
            </div>
          <% } %>
        </div>

