        <div class="mb-8">
          <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            <%= t('email.contacts') || 'Mailing List Contacts' %> <span class="text-sm font-normal text-gray-400">(<%= mailingContacts.length %>)</span>
          </h2>

          <% if (mailingContacts.length === 0) { %>
            <p class="text-sm text-gray-400 dark:text-gray-500 pl-7"><%= t('admin.noDeletedContacts') || 'No deleted contacts' %></p>
          <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
              <% mailingContacts.forEach(function(mc) { %>
              <div id="mc-<%= mc.id %>" class="flex flex-col bg-white dark:bg-gray-800 rounded-card shadow-card border border-gray-200 dark:border-gray-700 p-4 sm:p-6 opacity-75">
                <div class="flex-grow">
                  <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-gray-900 dark:text-white line-through decoration-red-500"><%= mc.email || '—' %></h3>
                    <span class="text-xs px-2 py-1 rounded-full font-medium bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300"><%= t('admin.deleted') || 'Deleted' %></span>
                  </div>
                  <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-300">
                    <% if (mc.name) { %><span><%= mc.name %></span><% } %>
                    <% if (mc.list_name) { %><span class="text-xs px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-700"><%= mc.list_name %></span><% } %>
                  </div>
                </div>
                <div class="flex items-center justify-between pt-3 border-t border-gray-200 dark:border-gray-700 mt-auto">
                  <form action="/api/admin/email/lists/<%= mc.list_id %>/contacts/<%= mc.id %>/restore" method="POST" hx-post="/api/admin/email/lists/<%= mc.list_id %>/contacts/<%= mc.id %>/restore" hx-target="#mc-<%= mc.id %>" hx-swap="outerHTML swap:300ms">
                    <%- include('../partials/csrf-field') %>
                    <button type="submit" data-requires-edit class="w-auto text-sm font-medium px-4 py-2 rounded-lg bg-green-600 text-white hover:bg-green-700 dark:bg-green-600 dark:hover:bg-green-500 transition cursor-pointer"><%= t('admin.restore') || 'Restore' %></button>
                  </form>
                </div>
              </div>
              <% }); %>
            </div>
          <% } %>
        </div>

        <% if (categories.length === 0 && users.length === 0 && reviews.length === 0 && emailTemplates.length === 0 && emailCampaigns.length === 0 && mailingLists.length === 0 && mailingContacts.length === 0) { %>
          <div class="text-center py-12">
            <svg class="w-16 h-16 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white"><%= t('admin.trashEmpty') || 'Trash is empty' %></h3>
          </div>
        <% } %>

<%- include('_admin-layout-close') %>
</body>
</html>
