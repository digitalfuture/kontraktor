            <p class="text-sm text-gray-400 dark:text-gray-500 pl-7"><%= t('admin.noDeletedReviews') || 'No deleted reviews' %></p>
          <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
              <% reviews.forEach(function(r) { %>
              <div id="review-<%= r.id %>" class="flex flex-col bg-white dark:bg-gray-800 rounded-card shadow-card border border-gray-200 dark:border-gray-700 p-4 sm:p-6 opacity-75">
                <div class="flex-grow">
                  <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-gray-900 dark:text-white line-through decoration-red-500">
                      <%= r.author_email || '—' %> <span class="text-yellow-500 font-normal">★ <%= r.rating %></span>
                    </h3>
                    <span class="text-xs px-2 py-1 rounded-full font-medium bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300"><%= t('admin.deleted') || 'Deleted' %></span>
                  </div>
                  <% if (r.comment) { %><p class="text-sm text-gray-500 dark:text-gray-300 mb-1 line-clamp-2"><%= r.comment %></p><% } %>
                  <p class="text-xs text-gray-400"><%= t('admin.moderation') || 'Moderation' %>: <%= r.is_approved ? t('common.yes') + ' ✓' : t('common.no') %></p>
