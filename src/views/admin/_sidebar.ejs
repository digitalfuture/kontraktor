<aside class="fixed inset-y-0 left-0 z-40 w-64 bg-gray-900 dark:bg-gray-950 text-white flex flex-col border-r border-gray-800 dark:border-gray-800 transform -translate-x-full min-[1600px]:translate-x-0 min-[1600px]:static transition-transform duration-300 ease-in-out">
  <div class="p-4 sm:p-6 border-b border-gray-800 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <!-- Close button (visible only below 1600px, positioned exactly in the same top-left corner as the hamburger trigger) -->
      <button onclick="const a=document.querySelector('aside');a.classList.add('-translate-x-full');a.classList.remove('translate-x-0')" class="min-[1600px]:hidden p-2 rounded-lg hover:bg-gray-800 active:bg-gray-700 text-gray-400 cursor-pointer transition-colors focus:outline-none" aria-label="Close sidebar">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
      <div class="flex items-baseline gap-2">
        <a href="/" class="text-xl font-bold text-orange-500 leading-none">Kontraktor</a>
        <p class="text-xs text-gray-400 leading-none"><%= typeof t !== 'undefined' ? t('nav.admin') : 'Admin Panel' %></p>
      </div>
    </div>
  </div>
  
  <nav class="flex-1 p-4 space-y-1">
    <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      <%= typeof t !== 'undefined' ? t('admin.dashboard') : 'Dashboard' %>
    </a>
    <a href="/admin/projects" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activePage !== 'undefined' && activePage === 'orders' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      <%= typeof t !== 'undefined' ? t('admin.projects') : 'Projects' %>
    </a>
    <a href="/admin/contractors" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activePage !== 'undefined' && activePage === 'contractors' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
      <%= typeof t !== 'undefined' ? t('admin.contractors') : 'Contractors' %>
    </a>
    <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activePage !== 'undefined' && activePage === 'users' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      <%= typeof t !== 'undefined' ? t('admin.users') : 'Users' %>
    </a>
    <a href="/admin/categories" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activePage !== 'undefined' && activePage === 'categories' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
      <%= typeof t !== 'undefined' ? t('admin.categories') : 'Categories' %>
    </a>
    <a href="/admin/reviews" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activePage !== 'undefined' && activePage === 'reviews' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
      <%= typeof t !== 'undefined' ? t('admin.reviews') : 'Reviews' %>
    </a>
    <a href="/admin/payments" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activePage !== 'undefined' && activePage === 'payments' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
      <%= typeof t !== 'undefined' ? t('admin.payments') : 'Payments' %>
    </a>
    <a href="/admin/diagrams" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activePage !== 'undefined' && activePage === 'diagrams' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
      <%= typeof t !== 'undefined' ? t('admin.diagrams') : 'Diagrams' %>
    </a>
    <a href="/admin/trash" class="flex items-center gap-3 px-4 py-3 rounded-lg transition <%= typeof activePage !== 'undefined' && activePage === 'trash' ? 'bg-orange-700 text-white' : 'text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
      <%= typeof t !== 'undefined' ? (t('admin.trash') || 'Trash') : 'Trash' %>
    </a>
  </nav>
  
  <div class="p-4 border-t border-gray-800">
    <!-- Back to site -->
    <a href="/" class="flex items-center gap-3 px-4 py-2 rounded-lg text-gray-300 hover:bg-gray-800 dark:hover:bg-gray-800 transition text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m0 0h12"/></svg>
      <%= typeof t !== 'undefined' ? t('nav.home') : 'Back to site' %>
    </a>
    <a href="/auth/logout" class="flex items-center gap-3 px-4 py-2 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-red-400 transition text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      <%= typeof t !== 'undefined' ? t('nav.logout') : 'Logout' %>
    </a>
  </div>
</aside>