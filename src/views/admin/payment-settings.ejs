<%- include('_admin-layout', { activePage: 'payments' }) %>

        <!-- Page Header -->
        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= typeof t !== 'undefined' ? t('admin.paymentSettings') : 'Payment Settings' %></h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= typeof t !== 'undefined' ? t('admin.paymentSettingsDesc') : 'Configure credit packages and pricing' %></p>
          </div>
          <a href="/admin/payments?lang=<%= locale %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition cursor-pointer">
            ← <%= typeof t !== 'undefined' ? t('admin.backToPayments') : 'Back to Payments' %>
          </a>
        </div>

        <!-- Free Mode Toggle -->
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4 mb-6">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-white"><%= typeof t !== 'undefined' ? t('admin.freeModeTitle') : 'Free Mode — Unlimited Projects' %></h3>
              <p class="text-sm text-gray-500 dark:text-gray-300 mt-1">
                <%= typeof t !== 'undefined' ? t('admin.freeModeDesc') : 'When ON: unlimited projects for all users. When OFF: 1 active project per user. Existing projects continue unaffected.' %>
              </p>
            </div>
            <form method="POST" action="/api/admin/payments/toggle-free-mode?lang=<%= locale %>">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <button type="submit" class="relative inline-flex items-center h-7 rounded-full w-12 transition-colors focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800 cursor-pointer <%= freeMode ? 'bg-green-600' : 'bg-gray-300 dark:bg-gray-600' %>">
                <span class="inline-block w-5 h-5 transform bg-white rounded-full shadow-sm transition-transform <%= freeMode ? 'translate-x-6' : 'translate-x-1' %>"></span>
              </button>
            </form>
          </div>
          <div class="mt-3">
            <% if (freeMode) { %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-full bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                <%= typeof t !== 'undefined' ? t('admin.freeModeOn') : 'unlimited projects for everyone' %>
              </span>
            <% } else { %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">
                <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>
                <%= typeof t !== 'undefined' ? t('admin.freeModeOff') : '1 active project per user' %>
              </span>
            <% } %>
          </div>
        </div>

        <!-- Platform Fee Mode Toggle -->
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4 mb-6">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-white"><%= typeof t !== 'undefined' ? t('admin.platformFeeMode') : 'Platform Fee Mode' %></h3>
              <p class="text-sm text-gray-500 dark:text-gray-300 mt-1">
                <%= typeof t !== 'undefined' ? t('admin.platformFeeModeDesc') : 'When disabled (free), contractors can bid without credits. When enabled, each bid costs 1 credit.' %>
              </p>
            </div>
            <form method="POST" action="/api/admin/payments/toggle-paid-mode?lang=<%= locale %>">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <button type="submit" class="relative inline-flex items-center h-7 rounded-full w-12 transition-colors focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800 cursor-pointer <%= paidMode ? 'bg-orange-700' : 'bg-gray-300 dark:bg-gray-600' %>">
                <span class="inline-block w-5 h-5 transform bg-white rounded-full shadow-sm transition-transform <%= paidMode ? 'translate-x-6' : 'translate-x-1' %>"></span>
              </button>
            </form>
          </div>
          <div class="mt-3">
            <% if (paidMode) { %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-full bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                PAID MODE — <%= typeof t !== 'undefined' ? t('admin.paidModeOn') : 'credits required for bidding' %>
              </span>
            <% } else { %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                FREE MODE — <%= typeof t !== 'undefined' ? t('admin.paidModeOff') : 'no credits required' %>
              </span>
            <% } %>
          </div>
        </div>

        <!-- Xendit Status -->
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4 mb-6">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-white"><%= typeof t !== 'undefined' ? t('admin.xenditStatus') : 'Xendit Status' %></h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= typeof t !== 'undefined' ? t('admin.xenditDesc') : 'Payment gateway integration status' %></p>
            </div>
            <span class="px-2.5 py-1 text-xs font-medium rounded-full <%= xenditConfigured ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400' %>">
              <%= xenditConfigured ? (typeof t !== 'undefined' ? t('admin.configured') : 'Configured') : (typeof t !== 'undefined' ? t('admin.notConfigured') : 'Not Configured') %>
            </span>
          </div>
        </div>

        <!-- Credit Packages -->
        <form method="POST" action="/api/admin/payments/settings?lang=<%= locale %>" class="space-y-4">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

          <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700">
              <h3 class="font-semibold text-gray-900 dark:text-white"><%= typeof t !== 'undefined' ? t('admin.creditPackages') : 'Credit Packages' %></h3>
            </div>
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700">
                  <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('admin.packageLabel') : 'Package' %></th>
                  <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('admin.creditsLabel') : 'Credits' %></th>
                  <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('admin.priceLabel') : 'Price (Rp)' %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                <% packages.forEach(function(pkg, i) { %>
                <tr>
                  <td class="px-4 py-3 text-gray-900 dark:text-gray-100 font-medium"><%= pkg.label %></td>
                  <td class="px-4 py-3 text-gray-700 dark:text-gray-300"><%= pkg.credits %></td>
                  <td class="px-4 py-3">
                    <input type="hidden" name="packages[<%= i %>][label]" value="<%= pkg.label %>">
                    <input type="hidden" name="packages[<%= i %>][credits]" value="<%= pkg.credits %>">
                    <input type="number" name="packages[<%= i %>][price]" value="<%= pkg.price %>" min="0" step="1000"
                      class="w-32 px-3 py-1.5 text-sm border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="flex justify-end">
            <button type="submit" class="px-6 py-2 text-sm font-medium text-white bg-orange-700 hover:bg-orange-800 rounded-lg transition cursor-pointer">
              <%= typeof t !== 'undefined' ? t('admin.saveSettings') : 'Save Settings' %>
            </button>
          </div>
        </form>

<%- include('_admin-layout-close') %>
<%- include('../partials/_expandable-rows') %>
<script src="/js/htmx.min.js" defer></script>
<script src="/js/main.js?v=1779944513366" defer></script>
</body>
</html>
