<!-- Admin language & theme controls (matches site header style) -->
<div class="flex items-center space-x-3">
  <!-- Edit mode toggle -->
  <%- include('_edit-mode') %>

  <!-- Language switcher -->
  <div class="flex items-center space-x-1" role="group" aria-label="Language switcher">
    <% typeof locales !== 'undefined' && locales.forEach(function(loc) { %>
      <a href="?lang=<%= loc %>" 
         class="px-2 py-1 rounded text-sm font-medium transition cursor-pointer
           <%= locale === loc ? 'bg-orange-100 dark:bg-orange-900/40 text-orange-700' : 'text-gray-500 dark:text-gray-300 hover:text-gray-700 dark:hover:text-gray-200' %>"
      >
        <%= loc.toUpperCase() %>
      </a>
    <% }); %>
  </div>
  
  <!-- Theme toggle -->
  <button type="button" id="admin-theme-toggle" class="p-2 rounded-lg text-gray-500 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition cursor-pointer" aria-label="Toggle dark mode">
    <!-- Sun icon (shown in dark mode) -->
    <svg id="admin-theme-toggle-sun" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"/>
    </svg>
    <!-- Moon icon (shown in light mode) -->
    <svg id="admin-theme-toggle-moon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/>
    </svg>
  </button>
</div>

<script>
(function() {
  var html = document.documentElement;
  var stored = null;
  try { stored = localStorage.getItem('theme'); } catch(e) {}
  
  function applyTheme(theme) {
    if (theme === 'dark') html.classList.add('dark');
    else html.classList.remove('dark');
    updateIcons();
  }
  
  function updateIcons() {
    var isDark = html.classList.contains('dark');
    var sun = document.getElementById('admin-theme-toggle-sun');
    var moon = document.getElementById('admin-theme-toggle-moon');
    if (sun) sun.classList.toggle('hidden', !isDark);
    if (moon) moon.classList.toggle('hidden', isDark);
  }
  
  if (stored === 'dark' || stored === 'light') applyTheme(stored);
  else if (window.matchMedia('(prefers-color-scheme: dark)').matches) applyTheme('dark');
  else applyTheme('light');
  
  var btn = document.getElementById('admin-theme-toggle');
  if (btn) btn.addEventListener('click', function() {
    var isDark = html.classList.contains('dark');
    var newTheme = isDark ? 'light' : 'dark';
    try { localStorage.setItem('theme', newTheme); } catch(e) {}
    applyTheme(newTheme);
  });
})();
</script>
