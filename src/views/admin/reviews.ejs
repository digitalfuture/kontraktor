<%- include('_admin-layout', { activePage: 'reviews' }) %>

        <!-- Bottom Row (Title & Actions) -->
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-4 sm:mb-8">
          <div>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white inline-flex items-center gap-2 leading-none">
              <%= t('admin.reviews') %> <span class="text-gray-400 dark:text-gray-500 font-normal">(<%= pagination.total %>)</span>
            </h1>
            <p class="text-gray-500 dark:text-gray-300 mt-2 text-sm sm:text-base leading-none"><%= t("admin.reviewModeration") %></p>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-card shadow-card border border-gray-200 dark:border-gray-700">
          <div class="overflow-x-auto">
            <table class="w-full table-auto">
              <thead class="bg-gray-50 dark:bg-gray-900/50">
                <tr>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 w-10"></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3">ID</th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3"><%= t("admin.author") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3"><%= t("admin.contractor") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3"><%= t("admin.rating") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 hidden lg:table-cell"><%= t("admin.description") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3"><%= t("projects.allStatuses") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 hidden lg:table-cell"><%= t("admin.date") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 hidden min-[1600px]:table-cell"><%= t("admin.actions") %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                <% if (reviews.length === 0) { %>
                <tr><td colspan="9" class="px-4 sm:px-6 py-8 text-center text-gray-500 dark:text-gray-300"><%= t('admin.noReviews') %></td></tr>
                <% } else { %>
                <% reviews.forEach(function(r) { %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition expand-trigger cursor-pointer" data-row-id="r<%= r.id %>">
                  <td class="px-4 sm:px-6 py-4 text-gray-400 dark:text-gray-500">
                    <svg class="w-4 h-4 expand-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-500 dark:text-gray-300">#<%= r.id %></td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-600 dark:text-gray-300 max-w-[150px] truncate"><%= r.author_email %></td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-600 dark:text-gray-300"><%= r.contractor_name || '—' %></td>
                  <td class="px-4 sm:px-6 py-4 text-sm">
                    <span class="text-yellow-500"><%= '★'.repeat(r.rating) %><%= '☆'.repeat(5 - r.rating) %></span>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-900 dark:text-white max-w-[200px] truncate hidden lg:table-cell"><%= r.comment || '—' %></td>
                  <td class="px-4 sm:px-6 py-4">
                    <%- include('../partials/_status-badge', { status: r.is_approved ? 1 : 0, type: 'review' }) %>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-500 dark:text-gray-300 hidden lg:table-cell"><%= r.created_at %></td>
                  <td class="px-4 sm:px-6 py-4 hidden min-[1600px]:table-cell" onclick="event.stopPropagation()">
                    <div class="flex gap-1.5 items-center flex-nowrap whitespace-nowrap">
                      <% if (!r.is_approved || !r.is_moderated) { %>
                      <form action="/admin/reviews/<%= r.id %>/moderate" method="POST" class="inline">
                      <%- include('../partials/csrf-field') %>
                        <input type="hidden" name="action" value="approve">
                        <button type="submit" title="<%= t('admin.approve') %>" class="text-xs px-2.5 py-1 rounded border bg-gray-50 hover:bg-green-50 dark:bg-gray-800 dark:hover:bg-green-950/30 text-gray-500 hover:text-green-600 dark:text-gray-400 dark:hover:text-green-400 border-gray-200 dark:border-gray-700 hover:border-green-200 dark:hover:border-green-900/50 transition cursor-pointer whitespace-nowrap">✓</button>
                      </form>
                      <form action="/admin/reviews/<%= r.id %>/moderate" method="POST" class="inline">
                      <%- include('../partials/csrf-field') %>
                        <input type="hidden" name="action" value="reject">
                        <button type="submit" title="<%= t('admin.reject') %>" class="text-xs px-2.5 py-1 rounded border bg-gray-50 hover:bg-red-50 dark:bg-gray-800 dark:hover:bg-red-950/30 text-gray-500 hover:text-red-600 dark:text-gray-400 dark:hover:text-red-400 border-gray-200 dark:border-gray-700 hover:border-red-200 dark:hover:border-red-900/50 transition cursor-pointer whitespace-nowrap">✗</button>
                      </form>
                      <% } %>
                      <form action="/admin/reviews/<%= r.id %>/delete" method="POST" class="inline" onsubmit="return confirm(t('admin.deleteReviewConfirm'))">
                      <%- include('../partials/csrf-field') %>
                        <button type="submit" title="<%= t('admin.delete') %>" class="text-xs px-2.5 py-1 rounded border bg-gray-50 hover:bg-red-50 dark:bg-gray-800 dark:hover:bg-red-950/30 text-gray-500 hover:text-red-600 dark:text-gray-400 dark:hover:text-red-400 border-gray-200 dark:border-gray-700 hover:border-red-200 dark:hover:border-red-900/50 transition cursor-pointer whitespace-nowrap">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <!-- Expandable detail row -->
                <tr class="expand-detail" id="detail-r<%= r.id %>" style="display:none;">
                  <td colspan="9" class="px-4 sm:px-6 py-4 bg-gray-50 dark:bg-gray-900/50 border-l-4 border-orange-500">
                    <div class="flex flex-col sm:flex-row gap-4">
                      <div class="flex-1">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t("admin.fullComment") %></p>
                        <p class="text-gray-900 dark:text-white text-sm"><%= r.comment || '—' %></p>
                      </div>
                      <div class="sm:w-48 space-y-1 text-sm">
                        <p class="text-gray-500 dark:text-gray-300"><%= t("admin.author") %> <span class="text-gray-900 dark:text-white"><%= r.author_email %></span></p>
                        <% if (r.contractor_name) { %>
                        <p class="text-gray-500 dark:text-gray-300"><%= t("admin.contractor") %> <span class="text-gray-900 dark:text-white"><%= r.contractor_name %></span></p>
                        <% } %>
                        <p class="text-gray-500 dark:text-gray-300"><%= t("admin.rating") %> <span class="text-yellow-500"><%= '★'.repeat(r.rating) %></span> /5</p>
                        <p class="text-gray-500 dark:text-gray-300"><%= t("admin.date") %> <span class="text-gray-900 dark:text-white"><%= r.created_at %></span></p>
                      </div>
                      <!-- Mobile Actions Section -->
                      <div class="min-[1600px]:hidden sm:w-48">
                        <p class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase mb-1"><%= t("admin.actions") %></p>
                        <div class="flex gap-2 items-center flex-wrap mt-1">
                          <% if (!r.is_approved || !r.is_moderated) { %>
                          <form action="/admin/reviews/<%= r.id %>/moderate" method="POST" class="inline">
                          <%- include('../partials/csrf-field') %>
                            <input type="hidden" name="action" value="approve">
                            <button type="submit" class="text-xs px-3 py-1.5 rounded-lg border bg-white dark:bg-gray-800 text-green-600 border-green-300 transition cursor-pointer whitespace-nowrap"><%= locale === 'id' ? 'Setujui' : 'Approve' %></button>
                          </form>
                          <form action="/admin/reviews/<%= r.id %>/moderate" method="POST" class="inline">
                          <%- include('../partials/csrf-field') %>
                            <input type="hidden" name="action" value="reject">
                            <button type="submit" class="text-xs px-3 py-1.5 rounded-lg border bg-white dark:bg-gray-800 text-red-500 border-red-300 transition cursor-pointer whitespace-nowrap"><%= locale === 'id' ? 'Tolak' : 'Reject' %></button>
                          </form>
                          <% } %>
                          <form action="/admin/reviews/<%= r.id %>/delete" method="POST" class="inline" onsubmit="return confirm(t('admin.deleteReviewConfirm'))">
                          <%- include('../partials/csrf-field') %>
                            <button type="submit" class="text-xs px-3 py-1.5 rounded-lg border bg-white dark:bg-gray-800 text-gray-600 border-gray-300 transition cursor-pointer whitespace-nowrap">🗑&nbsp;<%= t("admin.delete") %></button>
                          </form>
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
                <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <%- include('_pagination', { pagination: pagination }) %>
        </div>
      </div>

<%- include('_admin-layout-close') %>
<%- include('../partials/_expandable-rows') %>
</body>
</html>
