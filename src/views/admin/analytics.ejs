<%- include('_admin-layout') %>
<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold"><%= typeof t !== 'undefined' ? t('analytics.title') : 'Analytics' %></h1>
    <span class="text-xs text-gray-500 dark:text-gray-400">
      <%= typeof t !== 'undefined' ? t('analytics.lastUpdate') : 'Last update' %>: <%= new Date().toLocaleString(locale === 'id' ? 'id-ID' : 'en-US') %>
    </span>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-100 dark:bg-red-900/30 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded-lg mb-6">
      <p class="font-medium"><%= typeof t !== 'undefined' ? t('analytics.error') : 'Analytics Error' %></p>
      <p class="text-sm mt-1"><%= error %></p>
    </div>
  <% } else if (typeof configMissing !== 'undefined' && configMissing) { %>
    <div class="bg-yellow-100 dark:bg-yellow-900/30 border border-yellow-400 dark:border-yellow-700 text-yellow-700 dark:text-yellow-300 px-4 py-3 rounded-lg mb-6">
      <p class="font-medium"><%= typeof t !== 'undefined' ? t('analytics.notConfigured') : 'Analytics Not Configured' %></p>
      <p class="text-sm mt-1"><%= configMissing %></p>
    </div>
  <% } else { %>

  <!-- Realtime -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 p-4">
      <div class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider font-medium mb-1">
        <%= typeof t !== 'undefined' ? t('analytics.realtimeUsers') : 'Realtime Users' %>
      </div>
      <div class="text-3xl font-bold text-green-600 dark:text-green-400">
        <%= typeof realtime !== 'undefined' && realtime ? realtime.activeUsers : '—' %>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 p-4">
      <div class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider font-medium mb-1">
        <%= typeof t !== 'undefined' ? t('analytics.realtimePageViews') : 'Page Views (now)' %>
      </div>
      <div class="text-3xl font-bold"><%= typeof realtime !== 'undefined' && realtime ? realtime.pageViews : '—' %></div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 p-4">
      <div class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider font-medium mb-1">
        <%= typeof t !== 'undefined' ? t('analytics.todayUsers') : 'Today Users' %>
      </div>
      <div class="text-3xl font-bold"><%= typeof daily !== 'undefined' && daily ? daily.activeUsers : '—' %></div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 p-4">
      <div class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wider font-medium mb-1">
        <%= typeof t !== 'undefined' ? t('analytics.todayViews') : 'Today Page Views' %>
      </div>
      <div class="text-3xl font-bold"><%= typeof daily !== 'undefined' && daily ? daily.screenPageViews : '—' %></div>
    </div>
  </div>

  <% if (typeof daily !== 'undefined' && daily) { %>
  <!-- Today's Detailed Metrics -->
  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 p-4 mb-6">
    <h2 class="text-base font-semibold mb-4">
      <%= typeof t !== 'undefined' ? t('analytics.todaySummary') : 'Today\'s Summary' %>
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      <div>
        <div class="text-xs text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('analytics.newUsers') : 'New Users' %></div>
        <div class="text-lg font-semibold"><%= daily.newUsers %></div>
      </div>
      <div>
        <div class="text-xs text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('analytics.sessions') : 'Sessions' %></div>
        <div class="text-lg font-semibold"><%= daily.sessions %></div>
      </div>
      <div>
        <div class="text-xs text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('analytics.bounceRate') : 'Bounce Rate' %></div>
        <div class="text-lg font-semibold"><%= daily.bounceRate.toFixed(1) %>%</div>
      </div>
      <div>
        <div class="text-xs text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('analytics.avgDuration') : 'Avg Duration' %></div>
        <div class="text-lg font-semibold"><%= Math.floor(daily.avgSessionDuration / 60) %>m <%= Math.round(daily.avgSessionDuration % 60) %>s</div>
      </div>
      <div>
        <div class="text-xs text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('analytics.pagesPerSession') : 'Pages/Session' %></div>
        <div class="text-lg font-semibold">
          <%= daily.sessions > 0 ? (daily.screenPageViews / daily.sessions).toFixed(1) : '0.0' %>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Traffic Trend (last 7 days) -->
  <% if (typeof trend !== 'undefined' && trend && trend.length > 0) { %>
  <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 p-4 mb-6">
    <h2 class="text-base font-semibold mb-4">
      <%= typeof t !== 'undefined' ? t('analytics.trafficTrend') : 'Traffic Trend (7 days)' %>
    </h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 dark:border-gray-700">
            <th class="text-left py-2 px-3 text-gray-500 dark:text-gray-400 font-medium"><%= typeof t !== 'undefined' ? t('analytics.date') : 'Date' %></th>
            <th class="text-right py-2 px-3 text-gray-500 dark:text-gray-400 font-medium"><%= typeof t !== 'undefined' ? t('analytics.users') : 'Users' %></th>
            <th class="text-right py-2 px-3 text-gray-500 dark:text-gray-400 font-medium"><%= typeof t !== 'undefined' ? t('analytics.sessions') : 'Sessions' %></th>
            <th class="text-right py-2 px-3 text-gray-500 dark:text-gray-400 font-medium"><%= typeof t !== 'undefined' ? t('analytics.pageViews') : 'Page Views' %></th>
          </tr>
        </thead>
        <tbody>
          <% trend.forEach(function(d) { %>
          <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50">
            <td class="py-2 px-3 font-medium"><%= d.date %></td>
            <td class="py-2 px-3 text-right"><%= d.users %></td>
            <td class="py-2 px-3 text-right"><%= d.sessions %></td>
            <td class="py-2 px-3 text-right"><%= d.pageViews %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- Top Pages & Sources side by side -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Top Pages -->
    <% if (typeof topPages !== 'undefined' && topPages && topPages.length > 0) { %>
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 p-4">
      <h2 class="text-base font-semibold mb-4">
        <%= typeof t !== 'undefined' ? t('analytics.topPages') : 'Top Pages (7 days)' %>
      </h2>
      <div class="space-y-2">
        <% topPages.forEach(function(page) { %>
        <div class="flex items-center justify-between text-sm py-1.5 border-b border-gray-100 dark:border-gray-800 last:border-0">
          <div class="flex-1 min-w-0 mr-4">
            <div class="font-medium truncate" title="<%= page.title %>"><%= page.title || page.path %></div>
            <div class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= page.path %></div>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="font-semibold"><%= page.views %></div>
            <div class="text-xs text-gray-500 dark:text-gray-400"><%= page.users %> <%= typeof t !== 'undefined' ? t('analytics.users') : 'users' %></div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Traffic Sources -->
    <% if (typeof sources !== 'undefined' && sources && sources.length > 0) { %>
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 p-4">
      <h2 class="text-base font-semibold mb-4">
        <%= typeof t !== 'undefined' ? t('analytics.trafficSources') : 'Traffic Sources (7 days)' %>
      </h2>
      <div class="space-y-2">
        <% sources.forEach(function(src) { %>
        <div class="flex items-center justify-between text-sm py-1.5 border-b border-gray-100 dark:border-gray-800 last:border-0">
          <div class="font-medium"><%= src.source %></div>
          <div class="text-right flex-shrink-0">
            <div class="font-semibold"><%= src.users %> <%= typeof t !== 'undefined' ? t('analytics.users') : 'users' %></div>
            <div class="text-xs text-gray-500 dark:text-gray-400"><%= src.sessions %> <%= typeof t !== 'undefined' ? t('analytics.sessions') : 'sessions' %></div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>
  </div>

  <% } %>
</div>
<%- include('_admin-layout-close') %>
