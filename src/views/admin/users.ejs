<%- include('_admin-layout', { activePage: 'users' }) %>

        <!-- Bottom Row (Title & Actions) -->
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-4 sm:mb-8">
          <div>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white inline-flex items-center gap-2 leading-none">
              <%= t('admin.users') %> <span class="text-gray-400 dark:text-gray-500 font-normal">(<%= pagination.total %>)</span>
            </h1>
            <p class="text-gray-500 dark:text-gray-300 mt-2 text-sm sm:text-base leading-none">
              <%= t('admin.usersDesc') %>
            </p>
          </div>
        </div>

        <!-- Users Table Card -->
        <div id="paginated-list" class="bg-white dark:bg-gray-800 rounded-card shadow-card border border-gray-200 dark:border-gray-700">
          <div class="overflow-x-auto">
            <table class="w-full table-auto">
              <thead class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-200 dark:border-gray-700">
                <tr>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 w-10"></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 w-16">ID</th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3"><%= t('admin.name') %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden lg:table-cell"><%= t('admin.email') %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden md:table-cell"><%= t('admin.role') %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden md:table-cell"><%= t('admin.projectsShort') %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden lg:table-cell"><%= t('admin.telegram') %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden xl:table-cell"><%= t('admin.registered') %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 text-center w-16"><%= t('admin.status') %></th>
                  <th class="text-center text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden min-[1600px]:table-cell"><%= t('admin.actions') %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                <% if (users.length === 0) { %>
                <tr>
                  <td colspan="10" class="px-2 sm:px-3 py-12 text-center text-gray-500 dark:text-gray-400">
                    <%= t('admin.noUsers') %>
                  </td>
                </tr>
                <% } else { %>
                <% users.forEach(function(user) { %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition expand-trigger cursor-pointer" data-row-id="u<%= user.id %>">
                  <!-- Expand Arrow -->
                  <td class="px-2 sm:px-3 py-4 text-gray-400 dark:text-gray-500">
                    <svg class="w-4 h-4 expand-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </td>

                  <!-- ID -->
                  <td class="px-2 sm:px-3 py-4 text-sm font-semibold text-gray-500 dark:text-gray-400">#<%= user.id %></td>
                  
                  <!-- Name -->
                  <td class="px-2 sm:px-3 py-4 text-sm font-bold text-gray-900 dark:text-white"><%= user.name || '—' %></td>

                  <!-- Email -->
                  <td class="px-2 sm:px-3 py-4 text-sm text-gray-600 dark:text-gray-300 hidden lg:table-cell"><%= user.email %></td>
                  
                  <!-- Role badge -->
                  <td class="px-2 sm:px-3 py-4 hidden md:table-cell">
                    <%- include('../partials/_status-badge', { status: user.role, type: 'user' }) %>
                  </td>
                  
                  <!-- Activity columns (projects posted or credits balance) -->
                  <td class="px-2 sm:px-3 py-4 text-sm text-gray-600 dark:text-gray-300 hidden md:table-cell">
                    <% if (user.role === 'contractor') { %>
                      <span class="font-bold text-orange-700 dark:text-orange-400"><%= user.contractor_credits || 0 %></span>
                    <% } else if (user.role === 'client') { %>
                      <span class="font-bold text-blue-700 dark:text-blue-400"><%= user.projects_count || 0 %></span>
                    <% } else { %>
                      <span class="text-gray-400">—</span>
                    <% } %>
                  </td>
                  
                  <!-- Telegram -->
                  <td class="px-2 sm:px-3 py-4 text-sm text-gray-500 dark:text-gray-400 hidden lg:table-cell">
                    <% if (user.telegram_id) { %>
                      <span class="text-teal-600 dark:text-teal-400 font-medium">
                        <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                        </svg>
                        @<%= user.telegram_id %></span>
                    <% } else { %>
                      <span class="text-gray-400">—</span>
                    <% } %>
                  </td>
                  
                  <!-- Registered Date -->
                  <td class="px-2 sm:px-3 py-4 text-sm text-gray-500 dark:text-gray-400 hidden xl:table-cell">
                    <%= new Date(user.created_at).toLocaleDateString(locale === 'id' ? 'id-ID' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                  </td>

                  <!-- Active/Blocked status -->
                  <td class="px-2 sm:px-3 py-4 text-center">
                    <%- include('../partials/_status-badge', { status: user.is_active, type: 'contractor' }) %>
                  </td>
                  
                  <!-- Actions -->
                  <td class="px-2 sm:px-3 py-4 text-sm hidden min-[1600px]:table-cell" onclick="event.stopPropagation()">
                    <div class="flex items-center justify-center gap-1.5 flex-nowrap">
                      <!-- Block/Unblock toggle -->
                      <form action="/api/admin/users/<%= user.id %>/toggle-active" method="POST" class="inline">
                        <%- include('../partials/csrf-field') %>
                        <button type="submit" class="text-xs px-2 py-1 rounded border transition cursor-pointer <%= user.is_active != 0 ? 'bg-gray-50 hover:bg-red-50 dark:bg-gray-800 dark:hover:bg-red-950/30 text-gray-600 dark:text-gray-400 hover:text-red-600 dark:hover:text-red-400 border-gray-200 dark:border-gray-700 hover:border-red-200 dark:hover:border-red-900/50' : 'bg-gray-50 hover:bg-green-50 dark:bg-gray-800 dark:hover:bg-green-950/30 text-red-500 hover:text-green-600 dark:text-red-400 dark:hover:text-green-400 border-gray-200 dark:border-gray-700 hover:border-green-200 dark:hover:border-green-900/50' %>" title="<%= user.is_active != 0 ? t('admin.block') : t('admin.activate') %>">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <% if (user.is_active != 0) { %>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6"/>
                            <% } else { %>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                            <% } %>
                          </svg>
                        </button>
                      </form>
                      <%- include('../partials/_admin-user-actions', { user: user }) %>
                    </div>
                  </td>
                </tr>

                <!-- Expandable detail row -->
                <tr class="expand-detail" id="detail-u<%= user.id %>" style="display:none;">
                  <td colspan="10" class="px-2 sm:px-3 py-4 bg-gray-50 dark:bg-gray-900/50 border-l-4 border-orange-500">
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 text-sm">
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.email') %></p>
                        <p class="text-gray-900 dark:text-white font-semibold select-all"><%= user.email %></p>
                      </div>
                      <% if (user.telegram_id) { %>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.telegram') %></p>
                        <p class="text-teal-600 dark:text-teal-400 font-semibold">
                          <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                          </svg>
                          @<%= user.telegram_id %></p>
                      </div>
                      <% } %>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.phone') %></p>
                        <p class="text-gray-900 dark:text-white font-medium select-all"><%= user.phone || '—' %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.registered') %></p>
                        <p class="text-gray-900 dark:text-white font-medium">
                          <%= new Date(user.created_at).toLocaleDateString(locale === 'id' ? 'id-ID' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                        </p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.activity') %></p>
                        <p class="text-gray-900 dark:text-white font-medium">
                          <% if (user.role === 'contractor') { %>
                            <span class="text-orange-700 dark:text-orange-400 font-bold"><%= user.contractor_credits || 0 %> <%= t('admin.credits') %></span> (<%= t('admin.balance') %>)
                          <% } else if (user.role === 'client') { %>
                            <span class="text-blue-700 dark:text-blue-400 font-bold"><%= user.projects_count || 0 %> <%= t('admin.projectsShort') %></span> (<%= t('admin.posted') %>)
                          <% } else { %>
                            —
                          <% } %>
                        </p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.status') %></p>
                        <p class="text-gray-900 dark:text-white font-medium"><%= user.is_active != 0 ? t('admin.activeStatus') : t('admin.blockedStatus') %></p>
                      </div>
                      <!-- Mobile Actions Section -->
                      <div class="min-[1600px]:hidden">
                        <p class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase mb-1"><%= t('admin.actions') %></p>
                        <div class="flex items-center gap-2 flex-wrap mt-1">
                          <form action="/api/admin/users/<%= user.id %>/toggle-active" method="POST" class="inline">
                            <%- include('../partials/csrf-field') %>
                            <button type="submit" class="text-xs px-2.5 py-1.5 rounded-lg border bg-white dark:bg-gray-800 transition cursor-pointer <%= user.is_active != 0 ? 'text-gray-600 dark:text-gray-400 border-gray-300 dark:border-gray-600' : 'text-red-500 dark:text-red-400 border-red-300 dark:border-red-800' %>">
                              <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <% if (user.is_active != 0) { %>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6"/>
                                <% } else { %>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                                <% } %>
                              </svg>
                              <%= user.is_active != 0 ? t('admin.block') : t('admin.activate') %></button>
                          </form>
                          <%- include('../partials/_admin-user-actions', { user: user }) %>
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
          
          <!-- Pagination -->
          <%- include('_pagination', { pagination: pagination }) %>
        </div>

<%- include('_admin-layout-close') %>
<%- include('../partials/_expandable-rows') %>
</body>
</html>
