<%- include('_admin-layout', { activePage: 'payments' }) %>

        <!-- Page Header -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-6">
          <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= typeof t !== 'undefined' ? t('admin.paymentsList') : 'Payments' %></h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= typeof t !== 'undefined' ? t('admin.allPayments') : 'All payments across all contractors' %></p>
          </div>
          <a href="/admin/payments/settings?lang=<%= locale %>" class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-orange-700 hover:bg-orange-800 rounded-lg transition cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <%= typeof t !== 'undefined' ? t('admin.paymentSettings') : 'Settings' %>
          </a>
        </div>

        <!-- Filters -->
        <form method="GET" class="flex flex-col sm:flex-row gap-3 mb-6">
          <input type="hidden" name="lang" value="<%= locale %>">
          <select name="status" class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
            <option value=""><%= typeof t !== 'undefined' ? t('admin.allStatuses') : 'All Statuses' %></option>
            <option value="pending" <%= selectedStatus === 'pending' ? 'selected' : '' %>><%= typeof t !== 'undefined' ? t('admin.paymentStatus_pending') : 'Pending' %></option>
            <option value="completed" <%= selectedStatus === 'completed' ? 'selected' : '' %>><%= typeof t !== 'undefined' ? t('admin.paymentStatus_completed') : 'Completed' %></option>
            <option value="failed" <%= selectedStatus === 'failed' ? 'selected' : '' %>><%= typeof t !== 'undefined' ? t('admin.paymentStatus_failed') : 'Failed' %></option>
          </select>
          <div class="flex-1 flex gap-2">
            <input type="text" name="search" value="<%= searchQuery %>" placeholder="<%= typeof t !== 'undefined' ? t('admin.searchByContractor') : 'Search contractor' %>" class="flex-1 px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
            <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-orange-700 hover:bg-orange-800 rounded-lg transition cursor-pointer"><%= typeof t !== 'undefined' ? t('admin.filterBtn') : 'Filter' %></button>
            <% if (searchQuery || selectedStatus) { %>
              <a href="/admin/payments?lang=<%= locale %>" class="px-3 py-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition cursor-pointer"><%= typeof t !== 'undefined' ? t('admin.clearFilter') : 'Clear' %></a>
            <% } %>
          </div>
        </form>

        <!-- Payments Table -->
        <div id="paginated-list">
          <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
            <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700">
                <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400">ID</th>
                <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('admin.contractor') : 'Contractor' %></th>
                <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('admin.amount') : 'Amount' %></th>
                <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('admin.creditsLabel') : 'Credits' %></th>
                <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('admin.paymentStatus') : 'Status' %></th>
                <th class="hidden sm:table-cell px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('admin.paymentMethod') : 'Method' %></th>
                <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400"><%= typeof t !== 'undefined' ? t('admin.dateCol') : 'Date' %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              <% if (payments.length === 0) { %>
              <tr><td colspan="7" class="px-4 sm:px-6 py-8 text-center text-gray-500 dark:text-gray-300"><%= typeof t !== 'undefined' ? t('admin.noPayments') : 'No payments found' %></td></tr>
              <% } else { %>
              <% payments.forEach(function(p) { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
                <td class="px-4 py-3 text-gray-900 dark:text-gray-100 font-mono text-xs"><%= p.id %></td>
                <td class="px-4 py-3 min-w-[140px] sm:min-w-0">
                  <div class="text-gray-900 dark:text-gray-100 font-medium text-sm leading-tight"><%= p.contractor_name || p.contractor_email %></div>
                  <% if (p.contractor_email && p.contractor_name) { %><div class="text-xs text-gray-400 mt-0.5 truncate max-w-[200px]"><%= p.contractor_email %></div><% } %>
                </td>
                <td class="px-4 py-3 text-gray-900 dark:text-gray-100 font-medium whitespace-nowrap">Rp <%= Number(p.amount).toLocaleString() %></td>
                <td class="px-4 py-3 text-gray-700 dark:text-gray-300 text-center"><%= p.credits %></td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full
                    <%= p.status === 'completed' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' : '' %>
                    <%= p.status === 'pending' ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400' : '' %>
                    <%= p.status === 'failed' ? 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400' : '' %>
                  "><%= typeof t !== 'undefined' ? (t('admin.paymentStatus_' + p.status) || p.status) : p.status %></span>
                </td>
                <td class="hidden sm:table-cell px-4 py-3 text-gray-700 dark:text-gray-300"><%= p.payment_method || '—' %></td>
                <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-xs whitespace-nowrap"><%= new Date(p.created_at + 'Z').toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (payments.length > 0) { %>
        <%- include('_pagination', { pagination: pagination }) %>
        <% } %>
        </div>

<%- include('_admin-layout-close') %>
<%- include('../partials/_expandable-rows') %>
<script src="/js/htmx.min.js" defer></script>
<script src="/js/main.js?v=1779944513366" defer></script>
</body>
</html>
