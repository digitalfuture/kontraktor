<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
  <%- include('../partials/_head') %>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : 'bg-gray-100 dark:bg-gray-950 text-gray-900 dark:text-gray-100' %>">
  <%- include('../partials/_anti-flash') %>
  <%- include('_notification') %>
  <div class="flex flex-col min-h-screen">
    <div class="flex flex-1 min-h-0">
      <%- include('_sidebar', { activePage: activePage, t: typeof t !== 'undefined' ? t : null, locale: locale }) %>
      <div class="flex flex-col flex-1 min-w-0">
<%- include('../partials/_page-header', {
          sidebarBreakpoint: 'min-[1600px]',
          mobileBranding: '',
          mobileBrandingLink: '/admin',
          desktopSubtitle: typeof t !== 'undefined' ? t('nav.admin') : 'Admin Panel',
          pageTitle: '',
          isAdmin: true,
          controlsIdPrefix: 'admin',
          locale: typeof locale !== 'undefined' ? locale : 'en',
          locales: typeof locales !== 'undefined' ? locales : ['id', 'en'],
          showAdminLink: false,
          showAccountLink: true,
          t: typeof t !== 'undefined' ? t : null,
          user: typeof user !== 'undefined' ? user : null
        }) %>
        <main class="flex-1">
          <div class="p-4 sm:p-6 lg:p-8">
