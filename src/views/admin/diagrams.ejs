<%- include('_admin-layout', { activePage: 'diagrams' }) %>

      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold"><%= typeof t !== 'undefined' ? t('admin.diagrams') : 'Diagrams & Charts' %></h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= typeof t !== 'undefined' ? t('admin.diagramsSubtitle') : 'Site structure, user flows, and analytics charts' %></p>
        </div>
      </div>

      <!-- Tab Navigation -->
      <div class="flex gap-1 mb-6 border-b border-gray-200 dark:border-gray-700">
        <button onclick="switchTab('sitemap')" id="tab-sitemap" class="px-4 py-2.5 text-sm font-medium border-b-2 border-orange-500 text-orange-600 dark:text-orange-400 transition">🧭 <%= typeof t !== 'undefined' ? t('admin.sitemap') : 'Sitemap' %></button>
        <button onclick="switchTab('charts')" id="tab-charts" class="px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition">📊 <%= typeof t !== 'undefined' ? t('admin.charts') : 'Charts' %></button>
      </div>

      <!-- Tab: Sitemap -->
      <div id="panel-sitemap" class="block">
        <%- include('../partials/_admin_chart_card', {
          cardId: 'sitemap-card',
          chartId: 'sitemap-container',
          loadingId: '',
          title: typeof t !== 'undefined' ? t('admin.sitemapTitle') : 'Site Structure Diagram',
          desc: ''
        }) %>
        <p class="text-xs text-gray-400 mt-2"><%= typeof t !== 'undefined' ? t('admin.sitemapAutoNote') : 'Auto-generated from routes. Run npm run generate-sitemap to update.' %></p>
      </div>

      <!-- Tab: Charts -->
      <div id="panel-charts" class="hidden">
        <!-- Category Distribution + User Distribution (grid) -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
          <%- include('../partials/_admin_chart_card', {
            cardId: 'category-card',
            chartId: 'categoryChart',
            loadingId: 'cat-loading',
            title: typeof t !== 'undefined' ? t('admin.categoryDistribution') : 'Projects by Category',
            chartType: 'canvas'
          }) %>
          <%- include('../partials/_admin_chart_card', {
            cardId: 'user-card',
            chartId: 'userChart',
            loadingId: 'user-loading',
            title: typeof t !== 'undefined' ? t('admin.userDistribution') : 'User Base Distribution',
            chartType: 'canvas'
          }) %>
        </div>

        <!-- Sankey Diagram -->
        <%- include('../partials/_admin_chart_card', {
          cardId: 'sankey-card',
          chartId: 'sankey-chart',
          loadingId: 'sankey-loading',
          title: typeof t !== 'undefined' ? t('admin.projectFlow') : 'Project Flow (Sankey Diagram)',
          desc: typeof t !== 'undefined' ? t('admin.sankeyDesc') : ''
        }) %>

        <!-- Map Chart -->
        <%- include('../partials/_admin_chart_card', {
          cardId: 'map-card',
          chartId: 'map-chart',
          loadingId: 'map-loading',
          title: typeof t !== 'undefined' ? t('admin.geoDistribution') : 'Geographic Distribution',
          desc: typeof t !== 'undefined' ? t('admin.geoDesc') : ''
        }) %>
      </div>
      <!-- End Charts Tab -->

  <!-- Sitemap Fullscreen Modal -->
  <div id="sitemap-modal" class="fixed inset-0 z-50 hidden bg-black/80 flex items-center justify-center p-4">
    <div class="bg-gray-900 rounded-lg w-full h-[90vh] max-w-6xl flex flex-col">
      <div class="flex items-center justify-between p-4 border-b border-gray-700">
        <h3 class="font-semibold text-white"><%= typeof t !== 'undefined' ? t('admin.sitemapTitle') : 'Site Structure Diagram' %></h3>
        <button onclick="closeSitemapFull()" class="p-2 hover:bg-gray-700 rounded-lg text-gray-400 hover:text-white transition">✕</button>
      </div>
      <div id="sitemap-modal-content" class="flex-1 overflow-auto p-4"></div>
    </div>
  </div>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <!-- Mermaid.js for sitemap diagram -->
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
  <!-- D3.js for Sankey & Map -->
  <script src="/js/d3.min.js"></script>
  <script src="/js/d3-sankey.min.js"></script>
  <%- include('../partials/_admin_sankey') %>
  <%- include('../partials/_admin_map') %>

  <%- include('../partials/_chart-expand') %>
  <script>
<%
  // Pre-compute translations for JS
  const jsProjectsLabel = typeof t !== 'undefined' ? t('admin.projects') : 'Projects';
  const jsClientsLabel = typeof t !== 'undefined' ? t('admin.clients') : 'Clients';
  const jsContractorsLabel = typeof t !== 'undefined' ? t('admin.contractors') : 'Contractors';
  const jsAdminsLabel = typeof t !== 'undefined' ? t('admin.admins') : 'Admins';
%>
    // ── Tab Switching ─────────────────────────────────────────────────────
    function switchTab(tab) {
      document.querySelectorAll('[id^="tab-"]').forEach(el => {
        el.classList.remove('border-orange-500', 'text-orange-600', 'dark:text-orange-400');
        el.classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
      });
      document.querySelectorAll('[id^="panel-"]').forEach(el => el.classList.add('hidden'));
      const tabEl = document.getElementById('tab-' + tab);
      tabEl.classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');
      tabEl.classList.add('border-orange-500', 'text-orange-600', 'dark:text-orange-400');
      document.getElementById('panel-' + tab).classList.remove('hidden');
    }

    // ── Sitemap Loading ────────────────────────────────────────────────────
    function loadSitemap(target) {
      const container = target || document.getElementById('sitemap-container');
      if (!container) return;
      const isModal = container.id === 'sitemap-modal-content';
      container.innerHTML = '<div class="flex items-center justify-center w-full h-full min-h-[200px] text-gray-400"><div class="text-center"><svg class="w-10 h-10 mx-auto mb-3 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg><p>' + '<%= typeof t !== 'undefined' ? t('common.loading') : 'Loading...' %>' + '</p></div></div>';
      fetch('/static/docs/sitemap.html')
        .then(r => r.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const dataEl = doc.getElementById('sitemap-data');
          if (dataEl) {
            const data = JSON.parse(dataEl.textContent);
            container.innerHTML = '';
            renderSitemapTree(container, data);
          } else {
            container.innerHTML = '<p class="text-gray-400">' + '<%= typeof t !== 'undefined' ? t('admin.noSitemap') : 'No sitemap data found. Run' %>' + ' <code>npm run generate-sitemap</code>.</p>';
          }
        })
        .catch(err => {
          container.innerHTML = '<p class="text-red-400">Error loading sitemap: ' + err.message + '</p>';
        });
    }

    function renderSitemapTree(container, data) {
      container.style.overflow = '';
      container.style.overflowX = '';
      container.style.touchAction = '';
      container.style.minHeight = '200px';
      container.innerHTML = '';
      container.style.display = 'flex';
      container.style.alignItems = 'center';
      container.style.justifyContent = 'center';

      const color = d3.scaleOrdinal()
        .domain(['root','admin','auth','account','payments','public'])
        .range(['#ea580c','#2563eb','#7c3aed','#059669','#d97706','#6b7280']);

      const svg = d3.select(container).append('svg')
        .style('display', 'block')
        .style('width', '100%')
        .style('height', '100%')
        .attr('preserveAspectRatio', 'xMidYMid meet')
        .attr('viewBox', '0 0 1000 400');
      const g = svg.append('g');

      const nodeSepY = 22, nodeSepX = 140;
      let zoomStack = [];
      let isLoading = false;

      function isEmpty(node) { return !node.children || node.children.length === 0; }

      function draw(node) {
        isLoading = true;
        g.selectAll('*').remove();

        const root = d3.hierarchy(node.data);
        if (!root.children) { isLoading = false; return; }

        const treeLayout = d3.tree().nodeSize([nodeSepY, nodeSepX]).separation(() => 1);
        treeLayout(root);

        // Only 2 levels
        const visibleNodes = root.descendants().filter(d => d.depth <= 1);
        const visibleLinks = root.links().filter(l => l.target.depth <= 1);

        // Compute bounds with room for labels
        let x0 = Infinity, x1 = -Infinity, y0 = Infinity, y1 = -Infinity;
        visibleNodes.forEach(d => {
          const leftW = d.depth === 0 ? d.data.name.length * 10 + 20 : 0;
          const rightW = d.depth > 0 ? d.data.name.length * 8 + 30 : 0;
          if (d.y - leftW - 16 < x0) x0 = d.y - leftW - 16;
          if (d.y + rightW + 16 > x1) x1 = d.y + rightW + 16;
          if (d.x < y0) y0 = d.x;
          if (d.x > y1) y1 = d.x;
        });

        // Center tree within the fixed 1000×400 viewBox
        const padY = 30;
        const treeCx = (x0 + x1) / 2;
        const treeCy = (y0 + y1) / 2;
        g.attr('transform', 'translate(' + (500 - treeCx) + ',' + (200 - treeCy) + ')');

        // Links
        const linkGen = d3.linkHorizontal().x(d => d[0]).y(d => d[1]);
        g.selectAll('path')
          .data(visibleLinks)
          .join('path')
          .attr('fill', 'none')
          .attr('stroke', '#d1d5db')
          .attr('stroke-opacity', 0.5)
          .attr('stroke-width', 1.5)
          .attr('d', d => linkGen({ source: [d.source.y, d.source.x], target: [d.target.y, d.target.x] }));

        // Nodes
        const nodeG = g.selectAll('g')
          .data(visibleNodes)
          .join('g')
          .attr('class', d => 'node-group' + (isEmpty(d.data) ? ' nodrill' : ''));

        // Circle
        nodeG.append('circle')
          .attr('cx', d => d.y)
          .attr('cy', d => d.x)
          .attr('r', d => d.data.leaf ? 4 : 6)
          .attr('fill', d => color(d.data.category || 'public'))
          .attr('stroke', d => d3.color(color(d.data.category || 'public')).darker(0.4))
          .attr('stroke-width', 1.5);

        // Label — parent LEFT, children RIGHT
        nodeG.append('text')
          .attr('text-anchor', d => d.depth === 0 ? 'end' : 'start')
          .attr('x', d => d.depth === 0 ? d.y - 14 : d.y + 14)
          .attr('y', d => d.x + 5)
          .attr('font-size', d => d.depth === 0 ? '17px' : (d.data.leaf ? '12px' : '14px'))
          .attr('font-weight', d => d.depth === 0 ? '700' : '500')
          .attr('fill', d => {
            if (d.depth === 0) return '#ea580c';
            const isDark = container.closest('.dark');
            return isDark ? '#e2e8f0' : '#1f2937';
          })
          .text(d => {
            if (d.depth === 0) return d.data.name;
            let icon = d.data.leaf ? '📄' : '📁';
            return icon + ' ' + d.data.name;
          });

        // Child count
        nodeG.filter(d => !isEmpty(d.data) && d.depth > 0).append('text')
          .attr('text-anchor', 'start')
          .attr('x', d => d.y + 14)
          .attr('y', d => d.x + 19)
          .attr('font-size', '10px')
          .attr('fill', '#9ca3af')
          .text(d => {
            const count = d.data.children ? d.data.children.length : 0;
            return count > 0 ? count + ' page' + (count > 1 ? 's' : '') : '';
          });

        // Click handler
        nodeG.filter(d => !isEmpty(d.data))
          .style('cursor', 'pointer')
          .on('click', function(event, d) {
            if (isLoading) return;
            event.stopPropagation();
            zoomTo(d);
          });

        nodeG.filter(d => isEmpty(d.data))
          .style('cursor', 'default');

        isLoading = false;
      }

      function zoomTo(node) {
        zoomStack.push(node);
        draw(node);
      }

      // Click on container background (outside nodes) → zoom out
      container.addEventListener('click', function(event) {
        if (zoomStack.length > 1) {
          zoomStack.pop();
          draw(zoomStack[zoomStack.length - 1]);
        }
      });

      // Init
      zoomStack = [d3.hierarchy(data)];
      draw(zoomStack[0]);
    }

    function openSitemapFull() {
      const modal = document.getElementById('sitemap-modal');
      modal.classList.remove('hidden');
      loadSitemap(document.getElementById('sitemap-modal-content'));
    }

    function closeSitemapFull() {
      document.getElementById('sitemap-modal').classList.add('hidden');
    }

    // ── Chart.js: Category Bar Chart ──────────────────────────────────────
    const categoryStats = <%- JSON.stringify(categoryStats) %>;
    const roleStats = <%- JSON.stringify(roleStats) %>;

    // Colors
    const COLORS = ['#f97316','#22c55e','#3b82f6','#a855f7','#ec4899','#14b8a6','#eab308','#ef4444','#6366f1'];

    document.addEventListener('DOMContentLoaded', function() {
      // Load sitemap diagram on page load
      loadSitemap();

      // Category Chart
      const catCtx = document.getElementById('categoryChart')?.getContext('2d');
      if (catCtx && categoryStats.length) {
        new Chart(catCtx, {
          type: 'bar',
          data: {
            labels: categoryStats.map(c => c.name_en || c.slug),
            datasets: [{
              label: '<%= jsProjectsLabel %>',
              data: categoryStats.map(c => c.count),
              backgroundColor: categoryStats.map((_, i) => COLORS[i % COLORS.length] + '80'),
              borderColor: categoryStats.map((_, i) => COLORS[i % COLORS.length]),
              borderWidth: 1,
              borderRadius: 4,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, ticks: { stepSize: 1 } },
              x: { ticks: { maxRotation: 45 } }
            }
          }
        });
      }
      var catLoading = document.getElementById('cat-loading');
      if (catLoading) catLoading.style.display = 'none';

      // User Distribution Chart
      const userCtx = document.getElementById('userChart')?.getContext('2d');
      if (userCtx && roleStats.length) {
        const labels = {
          client: '<%= jsClientsLabel %>',
          contractor: '<%= jsContractorsLabel %>',
          admin: '<%= jsAdminsLabel %>'
        };
        new Chart(userCtx, {
          type: 'doughnut',
          data: {
            labels: roleStats.map(r => labels[r.role] || r.role),
            datasets: [{
              data: roleStats.map(r => r.count),
              backgroundColor: ['#22c55e', '#f97316', '#3b82f6'],
              borderWidth: 0,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { position: 'bottom' }
            }
          }
        });
      }
      var userLoading = document.getElementById('user-loading');
      if (userLoading) userLoading.style.display = 'none';

      // ── Sankey & Map via shared partials ──────────────────────────────────
      renderSankey('sankey-chart', '/api/admin/sankey', {
        columnLabels: ['<%= t("admin.clients") %>', '<%= t("admin.projects") %>', '<%= t("admin.contractorsLabel") %>'],
        legendItems: [['client', '<%= t("admin.clients") %>'], ['project', '<%= t("admin.projects") %>'], ['contractor', '<%= t("admin.contractorsLabel") %>']]
      });
      renderMap('map-chart');
    });
  </script>

<%- include('_admin-layout-close') %>
</body>
</html>
