<%- include('_admin-layout', { activePage: 'contractors' }) %>

        <!-- Bottom Row (Title & Actions) -->
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-4 sm:mb-8">
          <div>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white inline-flex items-center gap-2 leading-none">
              <%= t('admin.contractors') %> <span class="text-gray-400 dark:text-gray-500 font-normal">(<%= pagination.total %>)</span>
            </h1>
            <p class="text-gray-500 dark:text-gray-300 mt-2 text-sm sm:text-base leading-none"><%= t("admin.listContractors") %></p>
          </div>
        </div>

        <!-- Filters -->
        <div class="bg-white dark:bg-gray-800 rounded-card shadow-card border border-gray-200 dark:border-gray-700 p-4 mb-4">
          <div class="flex flex-col sm:flex-row gap-3">
            <input type="text" placeholder="<%= t('admin.searchByNameEmail') %>" class="flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none">
            <select class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none">
              <option value=""><%= t("admin.allStatuses") %></option>
              <option value="active"><%= t("admin.active") %></option>
              <option value="blocked"><%= t("admin.block") %></option>
            </select>
            <select class="px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none">
              <option value=""><%= t("admin.verification") %></option>
              <option value="verified"><%= t("admin.verified") %></option>
              <option value="unverified"><%= t("admin.unverified") %></option>
            </select>
          </div>
        </div>

        <div id="paginated-list" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="overflow-x-auto">
            <table class="w-full table-auto">
              <thead class="bg-gray-50 dark:bg-gray-900/50">
                <tr>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 w-10"></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3">ID</th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3"><%= t("admin.name") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden lg:table-cell"><%= t("admin.email") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3"><%= t("admin.rating") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden lg:table-cell"><%= t("admin.reviews") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden lg:table-cell"><%= t("admin.completedProjects") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden xl:table-cell"><%= t("admin.verified") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3"><%= t("projects.allStatuses") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 py-3 hidden min-[1600px]:table-cell"><%= t("admin.actions") %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                <% if (contractors.length === 0) { %>
                <tr><td colspan="10" class="px-2 sm:px-3 py-8 text-center text-gray-500 dark:text-gray-300"><%= t('admin.noContractors') %></td></tr>
                <% } else { %>
                <% contractors.forEach(function(s) { %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition expand-trigger cursor-pointer" data-row-id="s<%= s.id %>">
                  <td class="px-2 sm:px-3 py-4 text-gray-400 dark:text-gray-500">
                    <svg class="w-4 h-4 expand-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </td>
                  <td class="px-2 sm:px-3 py-4 text-sm text-gray-500 dark:text-gray-300">#<%= s.id %></td>
                  <td class="px-2 sm:px-3 py-4 text-sm font-medium text-gray-900 dark:text-white"><%= s.name || '—' %></td>
                  <td class="px-2 sm:px-3 py-4 text-sm text-gray-600 dark:text-gray-300 hidden lg:table-cell max-w-[180px] truncate"><%= s.email %></td>
                  <td class="px-2 sm:px-3 py-4 text-sm text-gray-900 dark:text-white font-medium">
                    <span class="text-yellow-500">★</span> <%= s.rating.toFixed(1) %>
                  </td>
                  <td class="px-2 sm:px-3 py-4 text-sm text-gray-600 dark:text-gray-300 hidden lg:table-cell"><%= s.reviews_count %></td>
                  <td class="px-2 sm:px-3 py-4 text-sm text-gray-600 dark:text-gray-300 hidden lg:table-cell"><%= s.completed_projects %></td>
                  <td class="px-2 sm:px-3 py-4 hidden xl:table-cell">
                    <%- include('../partials/_status-badge', { status: s.is_verified, type: 'contractor-verified' }) %>
                  </td>
                  <td class="px-2 sm:px-3 py-4">
                    <%- include('../partials/_status-badge', { status: s.is_active, type: 'contractor' }) %>
                  </td>
                  <td class="px-2 sm:px-3 py-4 hidden min-[1600px]:table-cell" onclick="event.stopPropagation()">
                    <div class="flex gap-1.5 items-center flex-nowrap whitespace-nowrap">
                      <%- include('../partials/_admin-contractor-actions', { c: s }) %>
                    </div>
                  </td>
                </tr>
                <!-- Expandable detail row -->
                <tr class="expand-detail" id="detail-s<%= s.id %>" style="display:none;">
                  <td colspan="10" class="px-2 sm:px-3 py-4 bg-gray-50 dark:bg-gray-900/50 border-l-4 border-orange-500">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 text-sm">
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t("admin.name") %></p>
                        <p class="text-gray-900 dark:text-white"><%= s.name || '—' %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t("admin.email") %></p>
                        <p class="text-gray-900 dark:text-white"><%= s.email %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t("admin.phone") %></p>
                        <p class="text-gray-900 dark:text-white"><%= s.phone || '—' %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t("admin.rating") %></p>
                        <p class="text-gray-900 dark:text-white"><span class="text-yellow-500">★</span> <%= s.rating.toFixed(1) %> / 5</p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t("admin.reviews") %></p>
                        <p class="text-gray-900 dark:text-white"><%= s.reviews_count %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t("admin.completedProjects") %></p>
                        <p class="text-gray-900 dark:text-white"><%= s.completed_projects %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t("admin.verified") %></p>
                        <p class="text-gray-900 dark:text-white"><%= s.is_verified ? t('common.yes') + ' ✓' : t('common.no') %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t("projects.allStatuses") %></p>
                        <p class="text-gray-900 dark:text-white"><%= s.is_active ? t('admin.activeStatus') : t('admin.blockedStatus') %></p>
                      </div>
                      <!-- Services list with toggles -->
                      <div class="col-span-full">
                        <p class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase mb-2"><%= t('admin.services') %></p>
                        <div class="flex flex-wrap gap-2">
                          <% if (s.services && s.services.length > 0) { %>
                            <% s.services.forEach(function(svc) { %>
                            <form action="/api/admin/contractors/<%= s.id %>/services/<%= svc.id %>/toggle" method="POST" class="inline">
                              <%- include('../partials/csrf-field') %>
                              <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-xs font-medium transition cursor-pointer <%= svc.is_active ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 border-green-200 dark:border-green-800 hover:bg-green-100 dark:hover:bg-green-900/30' : 'bg-gray-50 dark:bg-gray-800 text-gray-500 dark:text-gray-400 border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700' %>">
                                <span class="w-1.5 h-1.5 rounded-full <%= svc.is_active ? 'bg-green-500' : 'bg-gray-400' %>"></span>
                                <%= svc.display_name %>
                              </button>
                            </form>
                            <% }); %>
                          <% } else { %>
                            <span class="text-gray-400 text-xs"><%= t('admin.noServices') %></span>
                          <% } %>
                        </div>
                      </div>
                      <!-- Mobile Actions Section -->
                      <div class="min-[1600px]:hidden">
                        <p class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase mb-1"><%= t("admin.actions") %></p>
                        <div class="flex gap-2 items-center flex-wrap mt-1">
                          <%- include('../partials/_admin-contractor-actions', { c: s }) %>
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
                <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <%- include('_pagination', { pagination: pagination }) %>
        </div>

<%- include('_admin-layout-close') %>
<%- include('../partials/_expandable-rows') %>
</body>
</html>
