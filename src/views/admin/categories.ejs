<%- include('_admin-layout', { activePage: 'categories' }) %>

        <!-- Bottom Row (Title & Actions) -->
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6">
          <div>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white inline-flex items-center gap-2 leading-none">
              <%= t('admin.categories') %> <span class="text-gray-400 dark:text-gray-500 font-normal">(<%= categories.length %>)</span>
            </h1>
            <p class="text-gray-500 dark:text-gray-300 mt-2 text-sm leading-none"><%= t("admin.manageCategories") %></p>
          </div>
          <button onclick="document.getElementById('addCategoryModal').classList.remove('hidden')" data-requires-edit class="bg-orange-700 text-white px-4 py-2 rounded-lg hover:bg-orange-800 transition text-sm font-medium cursor-pointer">+ <%= t("admin.addCategory") %></button>
        </div>

        <!-- Add Category Modal -->
        <div id="addCategoryModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
          <div class="bg-surface dark:bg-surface-dark rounded-card p-6 w-full max-w-lg">
            <h2 class="text-lg font-bold mb-4"><%= t("admin.addCategory") %></h2>
            <form action="/admin/categories/create" method="POST">
        <%- include('../partials/csrf-field') %>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium mb-1"><%= t("admin.slug") %> *</label>
                  <input type="text" name="slug" required placeholder="e.g. plumbing" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100">
                </div>
                <div>
                  <label class="block text-sm font-medium mb-1"><%= t("admin.nameEn") %> *</label>
                  <input type="text" name="name_en" required placeholder="<%= t('admin.nameEn') %>" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100">
                </div>
                <div>
                  <label class="block text-sm font-medium mb-1"><%= t("admin.nameId") %></label>
                  <input type="text" name="name_id" placeholder="<%= t('admin.nameId') %>" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100">
                </div>
                <div>
                  <label class="block text-sm font-medium mb-1"><%= t("admin.descriptionEn") %></label>
                  <textarea name="description_en" rows="2" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100"></textarea>
                </div>
                <div>
                  <label class="block text-sm font-medium mb-1"><%= t("admin.descriptionId") %></label>
                  <textarea name="description_id" rows="2" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100"></textarea>
                </div>
              </div>
              <div class="flex gap-3 mt-6">
                <button type="submit" class="bg-orange-700 text-white px-4 py-2 rounded hover:bg-orange-800 transition cursor-pointer"><%= t("admin.create") %></button>
                <button type="button" onclick="document.getElementById('addCategoryModal').classList.add('hidden')" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-700 transition cursor-pointer"><%= t("admin.cancel") %></button>
              </div>
            </form>
          </div>
        </div>

        <!-- Delete Category Modal -->
        <div id="deleteCategoryModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
          <div class="bg-white dark:bg-gray-800 rounded-xl p-6 w-full max-w-sm">
            <h2 class="text-lg font-bold mb-4 text-gray-900 dark:text-white"><%= t("admin.confirmDelete") || "Confirm Deletion" %></h2>
            <p class="text-gray-600 dark:text-gray-300 mb-6 text-sm"><%= t("admin.deleteCategoryConfirm") %></p>
            <form id="deleteCategoryForm" action="" method="POST">
              <%- include('../partials/csrf-field') %>
              <div class="flex gap-3 justify-end">
                <button type="button" onclick="document.getElementById('deleteCategoryModal').classList.add('hidden')" class="px-4 py-2 text-sm font-medium border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition cursor-pointer text-gray-700 dark:text-gray-200"><%= t("admin.cancel") %></button>
                <button type="submit" class="bg-red-600 text-white px-4 py-2 text-sm font-medium rounded-lg hover:bg-red-700 transition cursor-pointer"><%= t("admin.delete") %></button>
              </div>
            </form>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          <% categories.forEach(function(cat) { %>
          <div class="flex flex-col bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6">
            <div class="flex-grow">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-semibold text-gray-900 dark:text-white"><%= cat.display_name || t('categories.' + cat.slug) %></h3>
                <span class="text-xs px-2 py-1 rounded-full font-medium <%= cat.is_active ? 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300' : 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300' %>"><%= cat.is_active ? t('admin.active') : t('admin.hidden') %></span>
              </div>
              <p class="text-sm text-gray-500 dark:text-gray-300 mb-3"><%= cat.description_en || '—' %></p>
              <div class="flex items-center justify-between text-sm mb-3">
                <span class="text-gray-500 dark:text-gray-300"><%= cat.sub_count %> <%= t("admin.subcategories") %></span>
                <span class="text-gray-400 dark:text-gray-500 text-xs">/<%= cat.slug %></span>
              </div>
            </div>
            <div class="flex items-center justify-between pt-3 border-t border-gray-200 dark:border-gray-700 mt-auto">
              <form action="/admin/categories/<%= cat.id %>/toggle" method="POST">
                <%- include('../partials/csrf-field') %>
                <button type="submit" class="w-auto text-sm font-medium px-4 py-2 rounded-lg transition <%= cat.is_active ? 'bg-gray-200 text-gray-800 hover:bg-gray-300 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600' : 'bg-green-600 text-white hover:bg-green-700 dark:bg-green-600 dark:hover:bg-green-500' %>"><%= cat.is_active ? t('admin.hide') : t('admin.show') %></button>
              </form>
              <button type="button" data-requires-edit onclick="const m=document.getElementById('deleteCategoryModal'); document.getElementById('deleteCategoryForm').action='/admin/categories/<%= cat.id %>/delete'; m.classList.remove('hidden');" class="w-auto text-sm font-medium px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700 dark:bg-red-600 dark:hover:bg-red-500 transition cursor-pointer"><%= t("admin.delete") %></button>
            </div>
          </div>
          <% }); %>
        </div>
      </div>

<%- include('_admin-layout-close') %>
</body>
</html>
