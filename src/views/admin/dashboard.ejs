<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
  <%- include('../partials/_head') %>
<body class="bg-gray-100 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
  <%- include('../partials/_anti-flash') %>
  <div class="flex h-screen overflow-hidden">
    <%- include('_sidebar', { activePage: 'dashboard', locale: locale }) %>
    <main class="flex-1 overflow-y-auto">
      <div class="p-4 sm:p-6 lg:p-8">
        <!-- Top Row (Header) -->
        <div class="flex items-center justify-between min-[1600px]:justify-end mb-4 sm:mb-8">
          <button onclick="const a=document.querySelector('aside');a.classList.toggle('-translate-x-full');a.classList.toggle('translate-x-0')" class="min-[1600px]:hidden p-2 rounded-lg bg-surface dark:bg-surface-dark border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 active:bg-gray-100 dark:active:bg-gray-600 transition-colors cursor-pointer w-max focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <div class="flex items-center">
            <%- include('_controls', { locale: locale, locales: typeof locales !== 'undefined' ? locales : ['id', 'en'] }) %>
          </div>
        </div>

        <!-- Bottom Row (Title & Actions) -->
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6 sm:mb-8">
          <div>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white leading-none"><%= t('admin.dashboard') %></h1>
            <p class="text-gray-500 dark:text-gray-300 mt-2 text-sm sm:text-base leading-none"><%= t("admin.overview") %></p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-6 sm:mb-8">
          <a href="/admin/projects" class="block bg-surface dark:bg-surface-dark rounded-card p-4 sm:p-6 shadow-card border border-gray-200 dark:border-gray-700 transition hover:scale-[1.02] hover:shadow-card-hover hover:border-blue-300 dark:hover:border-blue-900/50 group">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition"><%= t('admin.projects') %></h3>
              <span class="bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 text-xs px-2 py-1 rounded-full font-medium"><%= stats.pendingProjects %> <%= t("admin.new") %></span>
            </div>
            <p class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white"><%= stats.totalProjects %></p>
            <p class="text-sm text-gray-500 dark:text-gray-300 mt-1"><%= t('admin.totalProjects') %></p>
          </a>

          <a href="/admin/contractors" class="block bg-surface dark:bg-surface-dark rounded-card p-4 sm:p-6 shadow-card border border-gray-200 dark:border-gray-700 transition hover:scale-[1.02] hover:shadow-card-hover hover:border-orange-300 dark:hover:border-orange-900/50 group">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-300 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition"><%= t('admin.contractors') %></h3>
            </div>
            <p class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white"><%= stats.totalContractors %></p>
            <p class="text-sm text-gray-500 dark:text-gray-300 mt-1"><%= t('admin.totalContractors') %></p>
          </a>

          <a href="/admin/users" class="block bg-surface dark:bg-surface-dark rounded-card p-4 sm:p-6 shadow-card border border-gray-200 dark:border-gray-700 transition hover:scale-[1.02] hover:shadow-card-hover hover:border-purple-300 dark:hover:border-purple-900/50 group">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-300 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition"><%= t('admin.clients') %></h3>
            </div>
            <p class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white"><%= stats.totalClients %></p>
            <p class="text-sm text-gray-500 dark:text-gray-300 mt-1"><%= t('admin.totalInSystem') %></p>
          </a>

          <a href="/admin/reviews" class="block bg-surface dark:bg-surface-dark rounded-card p-4 sm:p-6 shadow-card border border-gray-200 dark:border-gray-700 transition hover:scale-[1.02] hover:shadow-card-hover hover:border-yellow-300 dark:hover:border-yellow-900/50 group">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-300 group-hover:text-yellow-600 dark:group-hover:text-yellow-400 transition"><%= t('admin.reviews') %></h3>
              <span class="bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-300 text-xs px-2 py-1 rounded-full font-medium"><%= stats.unmoderatedReviews %> <%= t('admin.pending') %></span>
            </div>
            <p class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white"><%= stats.totalReviews %></p>
            <p class="text-sm text-gray-500 dark:text-gray-300 mt-1"><%= t('admin.totalReviews') %></p>
          </a>
        </div>

        <!-- === ANALYTICAL CHARTS === -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
          <!-- Projects by Category Chart -->
          <div class="bg-surface dark:bg-surface-dark rounded-card p-4 sm:p-6 shadow-card border border-gray-200 dark:border-gray-700">
            <h2 class="text-sm sm:text-base font-semibold text-gray-900 dark:text-white mb-4"><%= t('admin.projectsByCategory') %></h2>
            <% 
              var maxCount = 1;
              categoryStats.forEach(function(c) {
                if (c.count > maxCount) maxCount = c.count;
              });
            %>
            <div class="space-y-4">
              <% categoryStats.forEach(function(c) { %>
              <% var pct = Math.round((c.count / maxCount) * 100); %>
              <div>
                <div class="flex items-center justify-between text-xs sm:text-sm mb-1.5">
                  <span class="text-gray-700 dark:text-gray-300 font-medium"><%= c.name %></span>
                  <span class="text-gray-900 dark:text-white font-bold"><%= c.count %></span>
                </div>
                <div class="w-full bg-gray-100 dark:bg-gray-700 rounded-full h-3.5 overflow-hidden">
                  <div class="bg-gradient-to-r from-orange-600 to-orange-400 h-full rounded-full transition-all duration-500 ease-out" style="width: <%= Math.max(pct, 2) %>%"></div>
                </div>
              </div>
              <% }); %>
            </div>
          </div>

          <!-- User Base Distribution Chart -->
          <div class="bg-surface dark:bg-surface-dark rounded-card p-4 sm:p-6 shadow-card border border-gray-200 dark:border-gray-700 flex flex-col justify-between">
            <div>
              <h2 class="text-sm sm:text-base font-semibold text-gray-900 dark:text-white mb-4"><%= t('admin.userDistribution') %></h2>
              <%
                var total = 0;
                var roleMap = { client: 0, contractor: 0, admin: 0 };
                roleStats.forEach(function(r) {
                  roleMap[r.role] = r.count;
                  total += r.count;
                });
                var clientPct = total > 0 ? Math.round((roleMap.client / total) * 100) : 0;
                var contractorPct = total > 0 ? Math.round((roleMap.contractor / total) * 100) : 0;
                var adminPct = total > 0 ? Math.round((roleMap.admin / total) * 100) : 0;
              %>

              <!-- Segmented Progress Bar -->
              <div class="w-full bg-gray-100 dark:bg-gray-700 rounded-full h-6 flex overflow-hidden mb-8 shadow-inner">
                <div class="bg-blue-500 h-full transition-all duration-500" style="width: <%= clientPct %>%" title="Clients: <%= clientPct %>%"></div>
                <div class="bg-orange-500 h-full transition-all duration-500" style="width: <%= contractorPct %>%" title="Contractors: <%= contractorPct %>%"></div>
                <div class="bg-red-500 h-full transition-all duration-500" style="width: <%= adminPct %>%" title="Admins: <%= adminPct %>%"></div>
              </div>

              <!-- Legends & Counts -->
              <div class="space-y-4">
                <div class="flex items-center justify-between border-b border-gray-200 dark:border-gray-700 pb-2.5">
                  <div class="flex items-center gap-2">
                    <span class="w-3.5 h-3.5 bg-blue-500 rounded-full"></span>
                    <span class="text-sm text-gray-700 dark:text-gray-300 font-medium"><%= t('admin.clients') %></span>
                  </div>
                  <div class="flex items-center gap-4">
                    <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded-md min-w-[48px] text-center"><%= clientPct %>%</span>
                    <span class="text-sm font-bold text-gray-900 dark:text-white min-w-[20px] text-right"><%= roleMap.client %></span>
                  </div>
                </div>

                <div class="flex items-center justify-between border-b border-gray-200 dark:border-gray-700 pb-2.5">
                  <div class="flex items-center gap-2">
                    <span class="w-3.5 h-3.5 bg-orange-500 rounded-full"></span>
                    <span class="text-sm text-gray-700 dark:text-gray-300 font-medium"><%= t('admin.contractorsLabel') %></span>
                  </div>
                  <div class="flex items-center gap-4">
                    <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded-md min-w-[48px] text-center"><%= contractorPct %>%</span>
                    <span class="text-sm font-bold text-gray-900 dark:text-white min-w-[20px] text-right"><%= roleMap.contractor %></span>
                  </div>
                </div>

                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <span class="w-3.5 h-3.5 bg-red-500 rounded-full"></span>
                    <span class="text-sm text-gray-700 dark:text-gray-300 font-medium"><%= t('admin.administrators') %></span>
                  </div>
                  <div class="flex items-center gap-4">
                    <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded-md min-w-[48px] text-center"><%= adminPct %>%</span>
                    <span class="text-sm font-bold text-gray-900 dark:text-white min-w-[20px] text-right"><%= roleMap.admin %></span>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-6 p-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg text-xs text-gray-500 dark:text-gray-300 text-center">
              Active database users: <span class="font-semibold text-gray-800 dark:text-gray-200"><%= total %></span>
            </div>
          </div>
        </div>

        <!-- === CHARTS: Sankey + Map (side by side on desktop) === -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
          <!-- Sankey Diagram Card -->
          <div class="bg-surface dark:bg-surface-dark rounded-card shadow-card border border-gray-200 dark:border-gray-700 overflow-hidden chart-card" id="sankey-card">
            <div class="p-4 sm:p-5 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
              <div>
                <h2 class="text-sm sm:text-base font-semibold text-gray-900 dark:text-white"><%= t('admin.sankeyTitle') %></h2>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= t('admin.sankeyDesc') %></p>
              </div>
              <button onclick="toggleExpand('sankey-card')" class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer expand-btn" title="Expand">
                <svg class="w-4 h-4 expand-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
                <svg class="w-4 h-4 collapse-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 9V4.5M9 9H4.5M9 9 3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5 5.25 5.25"/></svg>
              </button>
            </div>
            <div class="relative w-full h-[280px] sm:h-[400px] bg-slate-50 dark:bg-slate-900/50">
              <div id="sankey-chart" class="w-full h-full"></div>
              <div id="sankey-loading" class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none">
                <span class="text-gray-500 dark:text-gray-400 font-medium animate-pulse text-sm"><%= t('admin.loadingGraph') %></span>
              </div>
            </div>
          </div>

          <!-- Indonesia Map Card -->
          <div class="bg-surface dark:bg-surface-dark rounded-card shadow-card border border-gray-200 dark:border-gray-700 overflow-hidden chart-card" id="map-card">
            <div class="p-4 sm:p-5 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
              <div>
                <h2 class="text-sm sm:text-base font-semibold text-gray-900 dark:text-white"><%= t('admin.mapTitle') || 'Project Map' %></h2>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= t('admin.mapDesc') || 'Projects across Indonesia' %></p>
              </div>
              <button onclick="toggleExpand('map-card')" class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 cursor-pointer expand-btn" title="Expand">
                <svg class="w-4 h-4 expand-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
                <svg class="w-4 h-4 collapse-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 9V4.5M9 9H4.5M9 9 3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5 5.25 5.25"/></svg>
              </button>
            </div>
            <div class="relative w-full h-[280px] sm:h-[400px] bg-slate-50 dark:bg-slate-900/50">
              <div id="map-chart" class="w-full h-full overflow-hidden"></div>
              <div id="map-loading" class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none">
                <span class="text-gray-500 dark:text-gray-400 font-medium animate-pulse text-sm"><%= t('admin.loadingGraph') %></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Projects Table -->
        <div class="bg-surface dark:bg-surface-dark rounded-card shadow-card border border-gray-200 dark:border-gray-700 mb-6 sm:mb-8">
          <div class="p-4 sm:p-6 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white"><%= t('admin.projects') %></h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50 dark:bg-gray-900/50">
                <tr>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 w-10"></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 lg:px-6 py-3 w-10">ID</th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3"><%= t("admin.title") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 hidden sm:table-cell"><%= t("admin.client") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 hidden lg:table-cell"><%= t("admin.category") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3"><%= t("projects.allStatuses") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 hidden lg:table-cell"><%= t("admin.date") %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                <% if (recentProjects.length === 0) { %>
                <tr><td colspan="7" class="px-4 sm:px-6 py-8 text-center text-gray-500 dark:text-gray-300"><%= t('admin.noProjects') %></td></tr>
                <% } else { %>
                <% recentProjects.forEach(function(order) { %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition expand-trigger" data-row-id="do<%= order.id %>">
                  <td class="px-4 sm:px-6 py-4 text-gray-400 dark:text-gray-500">
                    <svg class="w-4 h-4 expand-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </td>
                  <td class="px-2 sm:px-3 lg:px-6 py-4 text-sm text-gray-500 dark:text-gray-300">#<%= order.id %></td>
                  <td class="px-4 sm:px-6 py-4 text-sm font-medium text-gray-900 dark:text-white max-w-[200px] truncate"><%= order.title %></td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-600 dark:text-gray-300 hidden sm:table-cell"><%= order.contact_name %></td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-600 dark:text-gray-300 hidden lg:table-cell"><%= order.category_name || '—' %></td>
                  <td class="px-4 sm:px-6 py-4">
                    <%- include('../partials/_status-badge', { status: order.status, type: 'project' }) %>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-500 dark:text-gray-300 hidden lg:table-cell"><%= order.created_at %></td>
                </tr>
                <tr class="expand-detail" id="detail-do<%= order.id %>" style="display:none;">
                  <td colspan="7" class="px-4 sm:px-6 py-4 bg-gray-50 dark:bg-gray-900/50 border-l-4 border-orange-500">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 text-sm">
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.title') %></p>
                        <p class="text-gray-900 dark:text-white"><%= order.title %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.client') %></p>
                        <p class="text-gray-900 dark:text-white"><%= order.contact_name %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.phone') %></p>
                        <p class="text-gray-900 dark:text-white"><%= order.contact_phone || '—' %></p>
                      </div>
                      <div class="sm:col-span-2 lg:col-span-3">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.description') %></p>
                        <p class="text-gray-900 dark:text-white"><%= order.description || '—' %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.category') %></p>
                        <p class="text-gray-900 dark:text-white"><%= order.category_name || '—' %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.address') %></p>
                        <p class="text-gray-900 dark:text-white"><%= order.district_display || '' %><% if (order.district_display && order.address) { %>, <% } %><%= order.address || '—' %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.date') %></p>
                        <p class="text-gray-900 dark:text-white"><%= order.created_at %></p>
                      </div>
                    </div>
                  </td>
                </tr>
                <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Recent Users Table -->
        <div class="bg-surface dark:bg-surface-dark rounded-card shadow-card border border-gray-200 dark:border-gray-700">
          <div class="p-4 sm:p-6 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white"><%= t('admin.recentUsers') %></h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50 dark:bg-gray-900/50">
                <tr>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 w-10"></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-2 sm:px-3 lg:px-6 py-3 w-10">ID</th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3"><%= t("admin.email") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 hidden sm:table-cell"><%= t("admin.name") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3"><%= t("admin.role") %></th>
                  <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase px-4 sm:px-6 py-3 hidden md:table-cell"><%= t("admin.date") %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                <% if (recentUsers.length === 0) { %>
                <tr><td colspan="6" class="px-4 sm:px-6 py-8 text-center text-gray-500 dark:text-gray-300"><%= t('admin.noUsers') %></td></tr>
                <% } else { %>
                <% recentUsers.forEach(function(u) { %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition expand-trigger" data-row-id="du<%= u.id %>">
                  <td class="px-4 sm:px-6 py-4 text-gray-400 dark:text-gray-500">
                    <svg class="w-4 h-4 expand-icon transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </td>
                  <td class="px-2 sm:px-3 lg:px-6 py-4 text-sm text-gray-500 dark:text-gray-300">#<%= u.id %></td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-900 dark:text-white max-w-[200px] truncate"><%= u.email %></td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-600 dark:text-gray-300 hidden sm:table-cell"><%= u.name || '—' %></td>
                  <td class="px-4 sm:px-6 py-4">
                    <%- include('../partials/_status-badge', { status: u.role, type: 'user' }) %>
                  </td>
                  <td class="px-4 sm:px-6 py-4 text-sm text-gray-500 dark:text-gray-300 hidden md:table-cell"><%= u.created_at %></td>
                </tr>
                <tr class="expand-detail" id="detail-du<%= u.id %>" style="display:none;">
                  <td colspan="6" class="px-4 sm:px-6 py-4 bg-gray-50 dark:bg-gray-900/50 border-l-4 border-orange-500">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.email') %></p>
                        <p class="text-gray-900 dark:text-white"><%= u.email %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.name') %></p>
                        <p class="text-gray-900 dark:text-white"><%= u.name || '—' %></p>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.role') %></p>
                        <div class="mt-1">
                          <%- include('../partials/_status-badge', { status: u.role, type: 'user' }) %>
                        </div>
                      </div>
                      <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-300 uppercase mb-1"><%= t('admin.date') %></p>
                        <p class="text-gray-900 dark:text-white"><%= u.created_at %></p>
                      </div>
                    </div>
                  </td>
                </tr>
                <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Sankey Diagram (D3) -->
  <script src="/js/d3.min.js"></script>
  <script src="/js/d3-sankey.min.js"></script>
  <%- include('../partials/_admin_sankey') %>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      renderSankey('sankey-chart', '/admin/api/sankey', {
        columnLabels: ['<%= t("admin.clients") %>', '<%= t("admin.projects") %>', '<%= t("admin.contractorsLabel") %>'],
        legendItems: [['client', '<%= t("admin.clients") %>'], ['project', '<%= t("admin.projects") %>'], ['contractor', '<%= t("admin.contractorsLabel") %>']]
      });
    });
  </script>

  <!-- Expand/Collapse Charts -->
  <style>
    .chart-card { transition: opacity 0.2s ease; }
    .chart-card.expanded {
      position: fixed !important;
      inset: 0 !important;
      z-index: 9999 !important;
      border-radius: 0 !important;
      margin: 0 !important;
      padding: 0 !important;
      width: 100vw !important;
      height: 100vh !important;
      display: flex !important;
      flex-direction: column !important;
      background: white !important;
    }
    .dark .chart-card.expanded {
      background: rgb(30 41 59) !important;
    }
    .chart-card.expanded > div:first-child {
      flex-shrink: 0 !important;
    }
    .chart-card.expanded > div:last-child {
      flex: 1 1 0 !important;
      min-height: 0 !important;
      height: auto !important;
    }
  </style>
  <script>
    function toggleExpand(id) {
      var card = document.getElementById(id);
      if (!card) return;
      var isExpanded = card.classList.toggle('expanded');
      var btn = card.querySelector('.expand-btn');
      if (btn) {
        btn.setAttribute('title', isExpanded ? 'Collapse' : 'Expand');
        var expandIcon = btn.querySelector('.expand-icon');
        var collapseIcon = btn.querySelector('.collapse-icon');
        if (expandIcon) expandIcon.classList.toggle('hidden', isExpanded);
        if (collapseIcon) collapseIcon.classList.toggle('hidden', !isExpanded);
      }
      // Re-render after layout
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          if (id === 'sankey-card') {
            var fn = window['_renderSankey_sankey-chart'];
            if (fn) fn();
          }
          if (id === 'map-card') {
            var fn = window['_renderMap_map-chart'];
            if (fn) fn();
          }
        });
      });
    }
  </script>

  <!-- Indonesia Map (D3) -->
  <%- include('../partials/_admin_map') %>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      renderMap('map-chart');
    });
  </script>
  <%- include('../partials/_expandable-rows') %>
</main>
</body>
</html>