<!DOCTYPE html>
<html lang="<%= locale %>">
  <%- include('partials/_head', { title: `${t('terms.title')} — ${t('site.name')}`, description: typeof t('terms.section1Text') === 'string' ? t('terms.section1Text').substring(0, 150) + '...' : '' }) %>
<body class="bg-gray-200 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
  <%- include('partials/_anti-flash') %>
  <%- include('partials/header') %>
  
  <main id="main-content" class="max-w-4xl mx-auto px-4 py-12 sm:py-16" role="main">
    <div class="bg-white dark:bg-gray-900 rounded-2xl p-8 sm:p-12 shadow-xl border border-gray-100 dark:border-gray-800 transition duration-300">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-orange-700 dark:text-orange-500 mb-6 tracking-tight">
        <%= t('terms.title') %>
      </h1>
      
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-8 border-b border-gray-100 dark:border-gray-850 pb-4">
        <%= t('terms.lastUpdated') %>
      </p>
      
      <div class="prose prose-orange dark:prose-invert max-w-none space-y-6 text-gray-700 dark:text-gray-300 leading-relaxed">
        <section>
          <h2 class="text-xl font-bold text-gray-950 dark:text-white mb-3"><%= t('terms.section1Title') %></h2>
          <p><%= t('terms.section1Text') %></p>
        </section>
        
        <section>
          <h2 class="text-xl font-bold text-gray-950 dark:text-white mb-3"><%= t('terms.section2Title') %></h2>
          <p><%= t('terms.section2Text') %></p>
        </section>
        
        <section>
          <h2 class="text-xl font-bold text-gray-950 dark:text-white mb-3"><%= t('terms.section3Title') %></h2>
          <p><%= t('terms.section3Text') %></p>
        </section>
        
        <section>
          <h2 class="text-xl font-bold text-gray-950 dark:text-white mb-3"><%= t('terms.section4Title') %></h2>
          <p><%= t('terms.section4Text') %></p>
        </section>
      </div>
      
      <div class="mt-12 pt-6 border-t border-gray-150 dark:border-gray-800 flex flex-col sm:flex-row justify-between items-center gap-4">
        <a href="/" class="text-orange-700 dark:text-orange-500 hover:underline text-sm font-semibold flex items-center gap-1">
          ← <%= t('terms.backHome') %>
        </a>
        <a href="/privacy" class="text-gray-500 hover:text-gray-700 dark:hover:text-white text-sm font-medium">
          <%= t('terms.viewPrivacy') %> →
        </a>
      </div>
    </div>
  </main>
  
  <%- include('partials/footer') %>
</body>
</html>
