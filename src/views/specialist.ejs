<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
  <%- include('partials/_head') %>
<body class="bg-gray-200 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
  <%- include('partials/_anti-flash') %>
  <%- include('partials/header') %>
  
  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-gray-900 dark:from-gray-950 to-gray-800 dark:to-gray-900 py-12 sm:py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
          <div>
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-4"><%= t('contractor.title') %></h1>
            <p class="text-gray-300 text-lg mb-8"><%= t('contractor.subtitle') %></p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/contractors/register" class="bg-orange-700 text-white px-8 py-3 rounded-lg hover:bg-orange-800 transition font-semibold text-center"><%= t('contractor.cta') %></a>
              <a href="/services" class="bg-transparent text-white border border-gray-500 px-8 py-3 rounded-lg hover:bg-gray-700 transition font-semibold text-center"><%= t('nav.services') %></a>
            </div>
          </div>
          <div class="hidden lg:block">
            <div class="bg-surface dark:bg-surface-dark rounded-card p-6 shadow-card">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/40 rounded-full"></div>
                <p class="font-semibold text-gray-900 dark:text-white"><%= t('contractor.exampleBid') %></p>
                <p class="text-sm text-gray-500 dark:text-gray-300"><%= t("contractor.exampleCity") %></p>
              </div>
            </div>
            <div class="bg-surface dark:bg-surface-dark rounded-card p-6 shadow-card mt-4 -ml-8">
              <p class="text-gray-700 dark:text-gray-300 mb-3"><%= t('contractor.exampleProject') %></p>
              <div class="flex items-center justify-between">
                <span class="text-orange-700 font-bold"><%= t("contractor.fromPrice") %></span>
                <span class="text-sm text-gray-500 dark:text-gray-300"><%= t("contractor.responses") %></span>
              </div>
            </div>
            <div class="bg-surface dark:bg-surface-dark rounded-card p-6 shadow-card mt-4 -ml-8">
              <div class="flex items-center gap-3 mb-3">
                <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="font-medium text-gray-900 dark:text-white"><%= t('contractor.projectCompleted') %></span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300"><%= t("contractor.earnedAmount") %></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-12 bg-gradient-to-b from-gray-200 to-gray-50 dark:from-gray-950 dark:to-gray-900 border-b border-gray-200 dark:border-gray-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div>
            <p class="text-3xl font-bold text-orange-700">10,000+</p>
            <p class="text-gray-600 dark:text-gray-300 mt-1"><%= t('contractor.statsProjects') %></p>
          </div>
          <div>
            <p class="text-3xl font-bold text-orange-700">5M Rp</p>
            <p class="text-gray-600 dark:text-gray-300 mt-1"><%= t('contractor.statsIncome') %></p>
          </div>
          <div>
            <p class="text-3xl font-bold text-orange-700"><%= t("contractor.responseTime") %></p>
            <p class="text-gray-600 dark:text-gray-300 mt-1"><%= t('contractor.statsResponse') %></p>
          </div>
          <div>
            <p class="text-3xl font-bold text-orange-700"><%= t('contractor.statsFreeLabel') %></p>
            <p class="text-gray-600 dark:text-gray-300 mt-1"><%= t('contractor.statsRegistration') %></p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-12 sm:py-16 bg-gray-50 dark:bg-gray-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-3 text-center"><%= t('howItWorks.title') %></h2>
        <p class="text-gray-600 dark:text-gray-300 text-center mb-12"><%= t('contractor.ctaSubtitle') %></p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <% t('contractor.benefits').forEach(function(benefit, i) { %>
          <div class="bg-surface dark:bg-surface-dark rounded-card p-6 shadow-card border border-gray-100 dark:border-gray-700">
            <div class="w-16 h-16 bg-orange-700 text-white rounded-full flex items-center justify-center text-2xl font-bold mb-4"><%= i + 1 %></div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3"><%= benefit.title %></h3>
            <p class="text-gray-600 dark:text-gray-300"><%= benefit.desc %></p>
          </div>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-12 sm:py-16 bg-white dark:bg-gray-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center"><%= t('contractor.whyTitle') %></h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex gap-4">
            <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/40 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-orange-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1"><%= t('contractor.guaranteedTitle') %></h3>
              <p class="text-gray-600 dark:text-gray-300"><%= t('contractor.guaranteedDesc') %></p>
            </div>
          </div>
          
          <div class="flex gap-4">
            <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/40 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-orange-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1"><%= t('contractor.localTitle') %></h3>
              <p class="text-gray-600 dark:text-gray-300"><%= t('contractor.localDesc') %></p>
            </div>
          </div>
          
          <div class="flex gap-4">
            <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/40 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-orange-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1"><%= t('contractor.reputationTitle') %></h3>
              <p class="text-gray-600 dark:text-gray-300"><%= t('contractor.reputationDesc') %></p>
            </div>
          </div>
          
          <div class="flex gap-4">
            <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/40 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-orange-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1"><%= t('contractor.easyStartTitle') %></h3>
              <p class="text-gray-600 dark:text-gray-300"><%= t('contractor.easyStartDesc') %></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 sm:py-16 bg-orange-600">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3"><%= t('contractor.ctaTitle') %></h2>
        <p class="text-lg text-white mb-8 max-w-xl mx-auto"><%= t('contractor.ctaSubtitle') %></p>
        <a href="/contractors/register" class="bg-white text-orange-700 px-8 py-3 rounded-lg hover:bg-orange-50 transition font-semibold text-lg shadow-lg">
          <%= t('contractor.cta') %>
        </a>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>