<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Kontraktor</title>
  <%- include('partials/_head') %>
</head>
<body class="bg-gray-200 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
  <%- include('partials/_anti-flash') %>
  <%- include('partials/header') %>

  <main id="main-content" class="max-w-5xl mx-auto px-4 sm:px-6 py-8" role="main">
    <!-- Contractor Header -->
    <section class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 sm:p-8 mb-6" aria-labelledby="contractor-name">
      <div class="flex items-start gap-6 flex-wrap">
        <% if (contractor.avatar_url) { %>
        <img src="<%= contractor.avatar_url %>" alt="<%= contractor.name %>" class="w-20 h-20 rounded-full object-cover border-2 border-orange-200 dark:border-orange-800" loading="lazy" width="80" height="80">
        <% } else { %>
        <div class="w-20 h-20 bg-orange-100 dark:bg-orange-900/30 rounded-full flex items-center justify-center text-3xl font-bold text-orange-700" aria-hidden="true">
          <%= contractor.name.charAt(0).toUpperCase() %>
        </div>
        <% } %>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 flex-wrap">
            <h1 id="contractor-name" class="text-2xl font-bold"><%= contractor.name %></h1>
            <% if (contractor.is_verified) { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300" aria-label="<%= t('contractorProfile.verified') %>">✓ <%= t('contractorProfile.verified') %></span>
            <% } %>
          </div>
          <div class="flex items-center gap-4 mt-2 text-sm text-gray-600 dark:text-gray-300">
            <% if (contractor.avg_rating > 0) { %>
            <span>⭐ <%= contractor.avg_rating.toFixed(1) %> (<%= contractor.review_count || 0 %> <%= t('contractorProfile.reviews') %>)</span>
            <% } %>
            <span>📁 <%= contractor.completed_projects || 0 %> <%= t('contractorProfile.projectsCompleted') %></span>
          </div>
          <% if (contractor.bio) { %>
          <p class="mt-4 text-gray-700 dark:text-gray-300"><%= contractor.bio %></p>
          <% } %>
        </div>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Stats -->
      <aside class="md:col-span-1 space-y-4" aria-label="<%= t('contractorProfile.statistics') %>">
        <section class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h3 class="text-lg font-semibold mb-4"><%= t('contractorProfile.statistics') %></h3>
          <dl class="space-y-3">
            <div class="flex justify-between">
              <dt class="text-gray-600 dark:text-gray-300"><%= t('contractorProfile.rating') %></dt>
              <dd class="font-medium"><%= stats ? stats.avg_rating.toFixed(1) : '0.0' %></dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600 dark:text-gray-300"><%= t('contractorProfile.reviews') %></dt>
              <dd class="font-medium"><%= stats ? stats.total_reviews : 0 %></dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-600 dark:text-gray-300"><%= t('contractorProfile.completed') %></dt>
              <dd class="font-medium"><%= contractor.completed_projects || 0 %></dd>
            </div>
          </dl>
        </section>

        <!-- Rating breakdown -->
        <% if (stats && stats.total_reviews > 0) { %>
        <section class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6" aria-labelledby="rating-breakdown">
          <h3 id="rating-breakdown" class="text-lg font-semibold mb-4"><%= t('contractorProfile.ratingBreakdown') %></h3>
          <div class="space-y-2">
            <% [5,4,3,2,1].forEach(function(star) { %>
            <div class="flex items-center gap-2 text-sm">
              <span class="w-8"><%= star %>★</span>
              <div class="flex-1 bg-gray-200 dark:bg-gray-700 rounded-full h-2" role="progressbar" aria-valuenow="<%= stats[star + '_star'] || 0 %>" aria-valuemin="0" aria-valuemax="<%= stats.total_reviews %>">
                <% var pct = stats.total_reviews > 0 ? (stats[star + '_star'] || 0) / stats.total_reviews * 100 : 0; %>
                <div class="bg-orange-500 h-2 rounded-full" style="width: <%= pct %>%"></div>
              </div>
              <span class="w-6 text-right text-gray-500"><%= stats[star + '_star'] || 0 %></span>
            </div>
            <% }); %>
          </div>
        </section>
        <% } %>
      </aside>

      <!-- Portfolio Photos -->
      <% if (photos && photos.length > 0) { %>
      <section class="md:col-span-2" aria-labelledby="portfolio-heading">
        <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h3 id="portfolio-heading" class="text-lg font-semibold mb-4">📸 <%= t('contractorProfile.portfolio') %></h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <% photos.forEach(function(photo) { %>
            <figure class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
              <img src="/uploads/<%= photo.filename %>" alt="<%= photo.caption || '' %>" class="w-full h-40 object-cover hover:scale-105 transition" loading="lazy">
              <% if (photo.caption) { %>
              <figcaption class="p-2 text-xs text-gray-600 dark:text-gray-300 truncate"><%= photo.caption %></figcaption>
              <% } %>
            </figure>
            <% }); %>
          </div>
        </div>
      </section>
      <% } %>

      <!-- Reviews -->
      <section class="md:col-span-2" aria-labelledby="reviews-heading">
        <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h3 id="reviews-heading" class="text-lg font-semibold mb-4"><%= t('contractorProfile.allReviews') %></h3>
          <% if (reviews.length === 0) { %>
          <p class="text-gray-500 dark:text-gray-300 text-center py-8"><%= t('contractorProfile.noReviews') %></p>
          <% } else { %>
          <div class="space-y-6">
            <% reviews.forEach(function(review) { %>
            <figure class="border-b border-gray-200 dark:border-gray-700 pb-4 last:border-0 last:pb-0">
              <figcaption class="flex items-center justify-between mb-2">
                <span class="font-medium"><%= review.reviewer_name || t('contractorProfile.anonymous') %></span>
                <time class="text-sm text-gray-500" datetime="<%= new Date(review.created_at).toISOString() %>"><%= new Date(review.created_at).toLocaleDateString('en-US') %></time>
              </figcaption>
              <div class="flex items-center gap-1 mb-2" role="img" aria-label="<%= review.rating %> out of 5 stars">
                <% for (var i = 0; i < 5; i++) { %>
                <span class="<%= i < review.rating ? 'text-orange-500' : 'text-gray-300 dark:text-gray-600' %>" aria-hidden="true">★</span>
                <% } %>
              </div>
              <blockquote class="text-gray-700 dark:text-gray-300"><%= review.comment %></blockquote>
            </figure>
            <% }); %>
          </div>
          <% } %>
        </div>
      </section>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
