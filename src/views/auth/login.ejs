<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
  <%- include('../partials/_head') %>
<body class="bg-gray-100 dark:bg-gray-950 min-h-screen flex items-center justify-center">
  <!-- Anti-flash -->
  <%- include('../partials/_anti-flash') %>
  
  <div class="max-w-md w-full mx-4">
    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8">
      <!-- Language + Theme row -->
      <div class="flex justify-end items-center space-x-3 mb-4">
        <% if (typeof locales !== 'undefined') { %>
        <div class="flex space-x-1">
          <% locales.forEach(function(loc) { %>
            <a href="?lang=<%= loc %>" class="px-2 py-1 rounded text-xs font-medium transition cursor-pointer <%= locale === loc ? 'bg-orange-100 dark:bg-orange-900/40 text-orange-700' : 'text-gray-500 dark:text-gray-300 hover:text-gray-700' %>"><%= loc.toUpperCase() %></a>
          <% }); %>
        </div>
        <% } %>
        <button id="theme-toggle" class="p-1.5 rounded-lg text-gray-500 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition cursor-pointer">
          <svg id="theme-toggle-sun" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"/></svg>
          <svg id="theme-toggle-moon" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/></svg>
        </button>
      </div>
      
      <div class="text-center mb-8">
        <a href="/" class="text-3xl font-bold text-orange-700">Kontraktor</a>
        <h1 class="text-xl font-semibold text-gray-900 dark:text-white mt-4"><%= t('auth.loginTitle') %></h1>
        <p class="text-gray-500 dark:text-gray-300 text-sm mt-2"><%= t('auth.loginSubtitle') %></p>
      </div>
      
      <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 px-4 py-3 rounded-lg mb-6 text-sm"><%= error %></div>
      <% } %>
      
      <form action="/api/auth/login" method="POST" class="space-y-4">
        <%- include('../partials/csrf-field') %>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"><%= t('auth.email') %></label>
          <input type="email" id="email" name="email" required placeholder="<%= t('auth.emailPlaceholder') %>"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent">
        </div>
        <div>
          <label for="telegram" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"><%= t('auth.telegram') %> <span class="text-gray-400 font-normal">(<%= t('auth.telegramOptional') %>)</span></label>
          <input type="text" id="telegram" name="telegram" placeholder="<%= t('auth.telegramPlaceholder') %>"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent">
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= t('auth.telegramHint') %></p>
        </div>
        <button type="submit" class="w-full bg-orange-700 text-white py-3 rounded-lg hover:bg-orange-800 transition font-semibold cursor-pointer">
          <%= t('auth.loginButton') %>
        </button>
      </form>
      
      <p class="text-center text-sm text-gray-500 dark:text-gray-300 mt-6">
        <a href="/" class="text-orange-700 hover:underline cursor-pointer">← <%= t("auth.backToHome") %></a>
      </p>
    </div>
  </div>
  
  <script>
    (function() {
      const html = document.documentElement;
      function applyTheme(theme) {
        if (theme === 'dark') html.classList.add('dark'); else html.classList.remove('dark');
        updateIcons();
      }
      function updateIcons() {
        const isDark = html.classList.contains('dark');
        const sun = document.getElementById('theme-toggle-sun');
        const moon = document.getElementById('theme-toggle-moon');
        if (sun) sun.classList.toggle('hidden', !isDark);
        if (moon) moon.classList.toggle('hidden', isDark);
      }
      const stored = localStorage.getItem('theme');
      if (stored === 'dark' || stored === 'light') applyTheme(stored);
      else if (window.matchMedia('(prefers-color-scheme: dark)').matches) applyTheme('dark');
      else applyTheme('light');
      document.getElementById('theme-toggle')?.addEventListener('click', function() {
        const isDark = html.classList.contains('dark');
        const newTheme = isDark ? 'light' : 'dark';
        localStorage.setItem('theme', newTheme);
        applyTheme(newTheme);
      });
    })();
  </script>
</body>
</html>