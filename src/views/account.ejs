<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
  <%- include('partials/_head') %>
<body class="bg-gray-200 dark:bg-gray-950 min-h-screen">
  <%- include('partials/_anti-flash') %>
  <%- include('partials/header') %>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white"><%= t('account.title') %></h1>
          <p class="text-gray-600 dark:text-gray-300 mt-1"><%= user.email %></p>
        </div>
        <% if (user.role === 'admin') { %>
          <a href="/admin" class="bg-gray-800 dark:bg-gray-200 text-white dark:text-gray-900 px-5 py-2 rounded-lg hover:bg-gray-900 dark:hover:bg-white transition font-medium">
            ⚙️ <%= t('nav.admin') %>
          </a>
        <% } %>
      </div>
    </div>

    <% var showTabs = clientCount > 0 || contractorCount > 0; %>

    <!-- Tabs -->
    <% if (showTabs) { %>
    <div class="border-b border-gray-200 dark:border-gray-700 mb-6">
      <nav class="-mb-px flex space-x-8 overflow-x-auto" id="account-tabs">
        <button
          onclick="switchTab('client')"
          id="tab-client"
          class="tab-btn <%= clientCount > 0 ? 'border-orange-600 text-orange-700' : 'border-transparent text-gray-500 dark:text-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
        >
          📋 <%= t('account.clientOrders') %> <span class="ml-1 bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-300 px-2 py-0.5 rounded-full text-xs"><%= clientCount %></span>
        </button>
        <% if (contractorCount > 0) { %>
        <button
          onclick="switchTab('contractor')"
          id="tab-contractor"
          class="tab-btn <%= clientCount > 0 ? 'border-transparent text-gray-500 dark:text-gray-300 hover:text-gray-700 dark:hover:text-gray-200 hover:border-gray-300 dark:hover:border-gray-600' : 'border-orange-600 text-orange-700' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
        >
          🔧 <%= t('account.contractorOrders') %> <span class="ml-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-2 py-0.5 rounded-full text-xs"><%= contractorCount %></span>
        </button>
        <% } %>
      </nav>
    </div>
    <% } %>

    <!-- Client Projects -->
    <div id="panel-client" class="tab-panel">
      <% if (clientProjects.length === 0) { %>
        <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 p-8 text-center">
          <p class="text-gray-500 dark:text-gray-300 text-lg mb-4"><%= t('account.noClientOrders') %></p>
          <p class="text-gray-400 dark:text-gray-500 text-sm mb-6"><%= t('account.noClientOrdersSub') %></p>
          <a href="/post" class="inline-block bg-orange-700 text-white px-6 py-2 rounded-lg hover:bg-orange-800 transition font-medium">
            <%= t('nav.postOrder') %>
          </a>
        </div>
      <% } else { %>
        <div class="space-y-4">
          <% clientProjects.forEach(function(project) { %>
            <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 p-5 sm:p-6 hover:shadow-md transition">
              <div class="flex items-start justify-between flex-wrap gap-4">
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white truncate"><%= project.title %></h3>
                  <p class="text-gray-600 dark:text-gray-300 text-sm mt-1 line-clamp-2"><%= project.description ? project.description.substring(0, 150) + '...' : '' %></p>
                  <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-3 text-sm text-gray-500 dark:text-gray-300">
                    <span>📁 <%= t('categories.' + project.category_slug) %></span>
                    <% if (project.subcategory_slug) { %>
                    <span>📂 <%= t('subcategories.' + project.subcategory_slug) %></span>
                    <% } %>
                    <% if (project.address) { %>
                    <span>📍 <%= project.address %></span>
                    <% } %>
                  </div>
                </div>
                <div class="text-right flex-shrink-0">
                  <%- include('partials/_status-badge', { status: project.status, type: 'project' }) %>
                  <% if (project.contractor_name) { %>
                    <p class="text-sm text-gray-500 dark:text-gray-300 mt-2"><%= t('account.master') %>: <%= project.contractor_name %></p>
                  <% } %>
                  <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= t('account.postedDate') %>: <%= new Date(project.created_at).toLocaleDateString('en-US') %></p>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Contractor Projects (assigned) -->
    <div id="panel-contractor" class="tab-panel hidden">
      <% if (contractorProjects.length === 0) { %>
        <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 p-8 text-center">
          <p class="text-gray-500 dark:text-gray-300 text-lg mb-4"><%= t('account.noContractorOrders') %></p>
          <p class="text-gray-400 dark:text-gray-500 text-sm"><%= t('account.noContractorOrdersSub') %></p>
        </div>
      <% } else { %>
        <div class="space-y-4">
          <% contractorProjects.forEach(function(project) { %>
            <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 p-5 sm:p-6 hover:shadow-md transition">
              <div class="flex items-start justify-between flex-wrap gap-4">
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white truncate"><%= project.title %></h3>
                  <p class="text-gray-600 dark:text-gray-300 text-sm mt-1 line-clamp-2"><%= project.description ? project.description.substring(0, 150) + '...' : '' %></p>
                  <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-3 text-sm text-gray-500 dark:text-gray-300">
                    <span>📁 <%= t('categories.' + project.category_slug) %></span>
                    <% if (project.subcategory_slug) { %>
                    <span>📂 <%= t('subcategories.' + project.subcategory_slug) %></span>
                    <% } %>
                    <span>👤 <%= t('account.client') %>: <%= project.contact_name %></span>
                  </div>
                </div>
                <div class="text-right flex-shrink-0">
                  <%- include('partials/_status-badge', { status: project.status, type: 'project' }) %>
                  <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= t('account.postedDate') %>: <%= new Date(project.created_at).toLocaleDateString('en-US') %></p>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    function switchTab(tab) {
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.tab-btn').forEach(t => {
        t.classList.remove('border-orange-600', 'text-orange-700');
        t.classList.add('border-transparent', 'text-gray-500');
      });
      document.getElementById('panel-' + tab).classList.remove('hidden');
      const activeTab = document.getElementById('tab-' + tab);
      if (activeTab) {
        activeTab.classList.remove('border-transparent', 'text-gray-500');
        activeTab.classList.add('border-orange-600', 'text-orange-700');
      }
    }
  </script>
</body>
</html>