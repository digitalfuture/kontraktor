<%- include('partials/_account-layout', { activeSection: typeof activeSection !== 'undefined' ? activeSection : 'overview', pageTitle: pageTitle }) %>

<!-- === OVERVIEW === -->
<% if (activeSection === 'overview') { %>

  <!-- Title & subtitle (like admin dashboard) -->
  <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6 sm:mb-8">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white leading-none"><%= t('account.title') %></h1>
      <p class="text-gray-500 dark:text-gray-300 mt-2 text-sm sm:text-base leading-none"><%= t('account.overviewSubtitle') %></p>
    </div>
  </div>

  <!-- Welcome + stats -->
  <div class="flex items-center justify-between flex-wrap gap-4 mb-8">
    <div>
      <p class="text-sm text-gray-500 dark:text-gray-300"><%= t('account.welcomeBack') %>, <strong><%= user.name || user.email %></strong></p>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5"><%= user.email %></p>
    </div>
    <div class="flex items-center gap-2">
      <% if (isContractor) { %>
        <div class="bg-green-100 dark:bg-green-900/30 px-4 py-2 rounded-lg">
          <span class="text-sm text-gray-600 dark:text-gray-300"><%= t('contractorDashboard.credits') %>:</span>
          <span class="text-xl font-bold ml-1 <%= paidMode ? 'text-orange-700' : 'text-green-700' %>"><%= paidMode ? (userCredits || 0) : t('projectDetail.freeCredits') %></span>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Quick stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
      <p class="text-sm text-gray-500 dark:text-gray-300"><%= t('account.clientOrders') %></p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= clientCount %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
      <p class="text-sm text-gray-500 dark:text-gray-300"><%= t('account.myBids') %></p>
      <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= bidsStats.total %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-yellow-200 dark:border-yellow-800 p-4">
      <p class="text-sm text-yellow-600 dark:text-yellow-400"><%= t('account.pending') %></p>
      <p class="text-2xl font-bold text-yellow-600 dark:text-yellow-400 mt-1"><%= bidsStats.pending %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-green-200 dark:border-green-800 p-4">
      <p class="text-sm text-green-600 dark:text-green-400"><%= t('account.accepted') %></p>
      <p class="text-2xl font-bold text-green-600 dark:text-green-400 mt-1"><%= bidsStats.accepted %></p>
    </div>
  </div>

  <!-- Quick actions -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <a href="/post" class="block bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md hover:border-orange-300 dark:hover:border-orange-700 transition group">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-orange-100 dark:bg-orange-900/40 flex items-center justify-center text-xl shrink-0">📋</div>
        <div>
          <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-orange-600 transition"><%= t('account.quickPost') %></h3>
          <p class="text-sm text-gray-500 dark:text-gray-300 mt-0.5"><%= t('account.quickPostDesc') %></p>
        </div>
      </div>
    </a>
    <a href="/projects" class="block bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md hover:border-orange-300 dark:hover:border-orange-700 transition group">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center text-xl shrink-0">🔍</div>
        <div>
          <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-orange-600 transition"><%= t('account.quickBrowse') %></h3>
          <p class="text-sm text-gray-500 dark:text-gray-300 mt-0.5"><%= t('account.quickBrowseDesc') %></p>
        </div>
      </div>
    </a>
  </div>

  <!-- Recent client projects -->
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 mb-8">
    <div class="p-6 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <h2 class="text-lg font-bold text-gray-900 dark:text-white"><%= t('account.recentProjects') %></h2>
      <a href="/account?section=projects" class="text-sm text-orange-600 hover:underline"><%= t('account.viewAll') %></a>
    </div>
    <% if (clientProjects.length === 0) { %>
      <div class="p-8 text-center">
        <p class="text-gray-500 dark:text-gray-300 mb-2"><%= t('account.noClientOrders') %></p>
        <p class="text-gray-400 dark:text-gray-500 text-sm"><%= t('account.noClientOrdersSub') %></p>
      </div>
    <% } else { %>
      <div class="divide-y divide-gray-200 dark:divide-gray-700">
        <% clientProjects.slice(0, 5).forEach(function(project) { %>
          <a href="/post/<%= project.id %>" class="block px-6 py-4 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-medium text-gray-900 dark:text-white"><%= project.title %></p>
                <p class="text-sm text-gray-500 dark:text-gray-300 mt-0.5"><%= project.category_name || project.category %></p>
              </div>
              <%- include('partials/_status-badge', { status: project.status, type: 'project' }) %>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Recent bids -->
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700">
    <div class="p-6 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <h2 class="text-lg font-bold text-gray-900 dark:text-white"><%= t('account.recentBids') %></h2>
      <a href="/account?section=bids" class="text-sm text-orange-600 hover:underline"><%= t('account.viewAll') %></a>
    </div>
    <% if (bids.length === 0) { %>
      <div class="p-8 text-center">
        <p class="text-gray-500 dark:text-gray-300 mb-2"><%= t('account.noBidsYet') %></p>
        <p class="text-gray-400 dark:text-gray-500 text-sm"><%= t('account.noBidsYetSub') %></p>
      </div>
    <% } else { %>
      <div class="divide-y divide-gray-200 dark:divide-gray-700">
        <% bids.slice(0, 5).forEach(function(bid) { %>
          <a href="/post/<%= bid.project_id %>" class="block px-6 py-4 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-medium text-gray-900 dark:text-white"><%= bid.project_title %></p>
                <p class="text-sm text-gray-500 dark:text-gray-300 mt-0.5"><%= t('account.bidDate') %>: <%= new Date(bid.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
              </div>
              <%- include('partials/_status-badge', { status: bid.status, type: 'project' }) %>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>

<!-- === MY PROJECTS (client) === -->
<% } else if (activeSection === 'projects') { %>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white"><%= t('account.clientOrders') %></h2>
      <p class="text-sm text-gray-500 dark:text-gray-300 mt-1"><%= t('account.allProjectsDesc') %></p>
    </div>
    <a href="/post" class="inline-flex items-center gap-1.5 bg-orange-700 text-white px-4 py-2 rounded-lg hover:bg-orange-800 transition text-sm font-medium">
      <span>+</span> <%= t('nav.postOrder') %>
    </a>
  </div>

  <% if (clientProjects.length === 0) { %>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-12 text-center">
      <p class="text-gray-500 dark:text-gray-300 text-lg mb-4"><%= t('account.noClientOrders') %></p>
      <p class="text-gray-400 dark:text-gray-500 text-sm mb-6"><%= t('account.noClientOrdersSub') %></p>
      <a href="/post" class="inline-block bg-orange-700 text-white px-6 py-2 rounded-lg hover:bg-orange-800 transition font-medium">
        <%= t('nav.postOrder') %>
      </a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% clientProjects.forEach(function(project) { %>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5 sm:p-6 hover:shadow-md transition">
          <div class="flex items-start justify-between flex-wrap gap-4">
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white truncate"><%= project.title %></h3>
              <p class="text-gray-600 dark:text-gray-300 text-sm mt-1 line-clamp-2"><%= project.description ? project.description.substring(0, 150) + '...' : '' %></p>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-3 text-sm text-gray-500 dark:text-gray-300">
                <span>📁 <%= t('categories.' + project.category_slug) %></span>
                <% if (project.subcategory_slug) { %>
                <span>📂 <%= t('subcategories.' + project.subcategory_slug) %></span>
                <% } %>
                <% if (project.address) { %>
                <span>📍 <%= project.address %></span>
                <% } %>
              </div>
            </div>
            <div class="text-right flex-shrink-0">
              <%- include('partials/_status-badge', { status: project.status, type: 'project' }) %>
              <% if (project.contractor_name) { %>
                <p class="text-sm text-gray-500 dark:text-gray-300 mt-2"><%= t('account.master') %>: <%= project.contractor_name %></p>
              <% } %>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= t('account.postedDate') %>: <%= new Date(project.created_at).toLocaleDateString('en-US') %></p>
              <a href="/post/<%= project.id %>" class="text-sm text-orange-600 hover:underline mt-2 inline-block"><%= t('account.viewDetails') %></a>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>

<!-- === MY BIDS (contractor) === -->
<% } else if (activeSection === 'bids') { %>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white"><%= t('account.myBids') %></h2>
      <p class="text-sm text-gray-500 dark:text-gray-300 mt-1"><%= t('account.allBidsDesc') %></p>
    </div>
    <a href="/projects" class="inline-flex items-center gap-1.5 bg-orange-700 text-white px-4 py-2 rounded-lg hover:bg-orange-800 transition text-sm font-medium">
      🔍 <%= t('nav.browseProjects') %>
    </a>
  </div>

  <% if (!isContractor) { %>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-12 text-center">
      <p class="text-gray-500 dark:text-gray-300 text-lg mb-4"><%= t('account.notContractor') %></p>
      <p class="text-gray-400 dark:text-gray-500 text-sm mb-6"><%= t('account.notContractorSub') %></p>
      <a href="/contractors/register" class="inline-block bg-orange-700 text-white px-6 py-2 rounded-lg hover:bg-orange-800 transition font-medium">
        <%= t('account.registerContractor') %>
      </a>
    </div>
  <% } else if (bids.length === 0) { %>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-12 text-center">
      <p class="text-gray-500 dark:text-gray-300 text-lg mb-4"><%= t('account.noBidsYet') %></p>
      <p class="text-gray-400 dark:text-gray-500 text-sm mb-6"><%= t('account.noBidsYetSub') %></p>
      <a href="/projects" class="inline-block bg-orange-700 text-white px-6 py-2 rounded-lg hover:bg-orange-800 transition font-medium">
        🔍 <%= t('nav.browseProjects') %>
      </a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% bids.forEach(function(bid) { %>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5 sm:p-6 hover:shadow-md transition">
          <div class="flex items-start justify-between flex-wrap gap-4">
            <div class="flex-1 min-w-0">
              <a href="/post/<%= bid.project_id %>" class="text-lg font-semibold text-gray-900 dark:text-white hover:text-orange-600 truncate block"><%= bid.project_title %></a>
              <div class="flex items-center gap-3 mt-1 text-sm text-gray-500 dark:text-gray-300">
                <span>📁 <%= bid.category_display %></span>
                <% if (bid.price) { %>
                <span>💵 Rp <%= bid.price %></span>
                <% } %>
              </div>
            </div>
            <div class="text-right flex-shrink-0">
              <%- include('partials/_status-badge', { status: bid.status, type: 'project' }) %>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= t('account.bidDate') %>: <%= new Date(bid.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>

<!-- === NOTIFICATIONS SETTINGS === -->
<% } else if (activeSection === 'notifications') { %>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white"><%= t('account.notifications') %></h2>
      <p class="text-sm text-gray-500 dark:text-gray-300 mt-1"><%= t('account.notificationsSubtitle') %></p>
    </div>
  </div>

  <% if (typeof notificationSuccess !== 'undefined' && notificationSuccess) { %>
  <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 px-4 py-3 rounded-lg mb-6">
    <%= t('account.notificationsSaved') %>
  </div>
  <% } %>

  <form method="POST" action="/account/notifications" class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700">
    <!-- Enable/disable toggle -->
    <div class="p-6 border-b border-gray-200 dark:border-gray-700">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="font-semibold text-gray-900 dark:text-white"><%= t('account.enableNotifications') %></h3>
          <p class="text-sm text-gray-500 dark:text-gray-300 mt-0.5"><%= t('account.enableNotificationsDesc') %></p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" name="enabled" value="1" class="sr-only peer" <%= typeof user !== 'undefined' && user.notifications_enabled ? 'checked' : '' %>>
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-orange-300 dark:peer-focus:ring-orange-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-orange-600"></div>
        </label>
      </div>
    </div>

    <!-- Category selection -->
    <div class="p-6">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-4"><%= t('account.notificationCategories') %></h3>
      <p class="text-sm text-gray-500 dark:text-gray-300 mb-4"><%= t('account.notificationCategoriesDesc') %></p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% categories.forEach(function(cat) { %>
        <label class="flex items-center gap-3 p-3 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 transition cursor-pointer">
          <input type="checkbox" name="categories" value="<%= cat.slug %>" class="w-4 h-4 text-orange-600 bg-gray-100 border-gray-300 rounded focus:ring-orange-500 dark:focus:ring-orange-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600" <%= userCats.includes(cat.slug) ? 'checked' : '' %>>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300"><%= t('categories.' + cat.slug) %></span>
        </label>
        <% }); %>
      </div>
    </div>

    <!-- Submit -->
    <div class="p-6 border-t border-gray-200 dark:border-gray-700 flex justify-end">
      <button type="submit" class="bg-gradient-to-r from-orange-600 to-amber-500 text-white px-6 py-2.5 rounded-lg hover:from-orange-700 hover:to-amber-600 transition font-medium">
        <%= t('account.saveNotifications') %>
      </button>
    </div>
  </form>

<% } %>
</body>
</html>
