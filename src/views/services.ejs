<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'en' %>">
  <%- include('partials/_head') %>
<body class="bg-gray-200 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
  <!-- Anti-flash -->
  <%- include('partials/_anti-flash') %>

  <%- include('partials/header') %>
  
  <main>
    <!-- Header -->
    <section class="bg-gradient-to-br from-orange-50 dark:from-gray-900 to-gray-200 dark:to-gray-950 py-8 sm:py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-3"><%= t('services.title') %></h1>
        <p class="text-gray-600 dark:text-gray-300 text-lg max-w-2xl"><%= t('services.subtitle') %></p>
        
        <!-- Search -->
        <div class="mt-6 max-w-xl">
          <div class="relative">
            <input type="text" id="service-search" placeholder="<%= t('services.findService') %>" class="w-full px-4 py-3 pl-10 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-700 focus:border-transparent">
            <svg class="absolute left-3 top-3.5 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-8 sm:py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="services-grid">
          <% services.forEach(function(service) { %>
          <a href="/services/<%= service.slug %>" class="service-card block bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-6 hover:shadow-lg hover:border-orange-300 dark:hover:border-orange-600 transition group">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/40 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-orange-700 group-hover:scale-110 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <%- iconMap[service.slug] || defaultIcon %>
                </svg>
              </div>
              <span class="text-sm text-gray-500 dark:text-gray-300"><%= service.totalContractors %> <%= t('services.contractors') %></span>
            </div>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-orange-600 transition"><%= t('categories.' + service.slug) %></h2>
            <p class="text-sm text-gray-600 dark:text-gray-300 mb-4"><%= service.description %></p>
            <div class="border-t border-gray-100 dark:border-gray-700 pt-3">
              <% service.subcategories.slice(0, 3).forEach(function(sub) { %>
              <div class="flex items-center justify-between py-1.5">
                <span class="text-sm text-gray-700 dark:text-gray-300"><%= t('subcategories.' + sub.slug) %></span>
                <span class="text-sm text-orange-700 dark:text-orange-400 font-medium flex items-center gap-1 flex-wrap">
                  <%= t('services.priceFrom') %> <%= sub.priceFrom %>
                  <% if (sub.count === 0) { %>
                    <span class="text-[10px] text-gray-500 dark:text-gray-400 font-normal font-sans">(<%= t('services.marketPrice').toLowerCase() %>)</span>
                  <% } %>
                </span>
              </div>
              <% }); %>
              <% if (service.subcategories.length > 3) { %>
              <p class="text-sm text-orange-700 mt-1">+ <%= service.subcategories.length - 3 %> <%= t('services.more') %></p>
              <% } %>
            </div>
          </a>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 sm:py-16 bg-gray-50 dark:bg-gray-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-3"><%= t('services.needSomethingElse') %></h2>
        <p class="text-gray-600 dark:text-gray-300 mb-6"><%= t('services.ctaPostProject') %></p>
        <a href="/post" class="bg-orange-700 text-white px-8 py-3 rounded-lg hover:bg-orange-800 transition font-semibold text-lg shadow-lg shadow-orange-600/30">
          <%= t('nav.postOrder') %>
        </a>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Client-side search
    document.getElementById('service-search')?.addEventListener('input', function() {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.service-card').forEach(function(card) {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(q) ? '' : 'none';
      });
    });
  </script>
</body>
</html>
