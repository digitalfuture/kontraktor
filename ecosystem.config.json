{
  "apps": [{
    "name": "kontraktor",
    "script": "dist/index.js",
    "instances": 1,
    "exec_mode": "fork",
    "env": {
      "NODE_ENV": "production",
      "PORT": 3002
    },
    "max_memory_restart": "300M",
    "error_file": "/root/kontraktor/logs/error.log",
    "out_file": "/root/kontraktor/logs/out.log",
    "merge_logs": true,
    "kill_timeout": 5000,
    "watch": false,
    "autorestart": true,
    "restart_delay": 3000
  }]
}
